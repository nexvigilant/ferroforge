# Cloud Run upload rules (overrides .gitignore for gcloud run deploy)
# bin/rsk is gitignored (pre-built binary shouldn't be in git history)
# but IS needed in the Docker build context for Cloud Run deployment.

# build artifacts
/target

# editor
*.swp
.DS_Store

# environment
.env
.env.*

# logs
*.log

# telemetry
*.jsonl

# python
__pycache__/
*.pyc

# claude code internal state
.claude/

# temp
restart-mcp/
hub/hub.db

# git history (not needed in build context)
.git/

# NOTE: bin/ is intentionally NOT excluded here.
# The rsk binary must be uploaded for the microgram proxy.
