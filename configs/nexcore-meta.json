{
  "domain": "nexcore-meta.nexvigilant.com",
  "url_pattern": "/*",
  "title": "NexCore Meta",
  "description": "NexCore health probes, system status, and meta-information endpoints",
  "tools": [
    {
      "name": "nexcore-assist",
      "description": "Nexcore Assist",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "nexcore-health",
      "description": "Nexcore Health",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "rust-native"
}
