{
  "domain": "calculate.nexvigilant.com",
  "private": false,
  "url_pattern": "/calculate/*",
  "title": "PV Calculation Engine",
  "copyright": "\u00a9 2026 NexVigilant, LLC. Signal half-life model, NexVigilant QBR Framework, and composite scoring methodology are proprietary. Standard PV algorithms (PRR, ROR, IC, EBGM, Naranjo, WHO-UMC) follow published methodologies.",
  "description": "Pharmacovigilance computation tools: signal detection (PRR/ROR/IC/EBGM), causality assessment (Naranjo, WHO-UMC), seriousness classification (ICH E2A), benefit-risk analysis, and reporting rate calculations. Standard algorithms follow published WHO, FDA, and ICH methodologies. Composite scoring and signal half-life models are proprietary NexVigilant methods.",
  "tools": [
    {
      "name": "compute-prr",
      "description": "Compute Proportional Reporting Ratio (PRR) for a drug-event pair from a 2x2 contingency table. PRR > 2 with chi-squared > 4 and N >= 3 indicates a signal.",
      "parameters": [
        {
          "name": "a",
          "type": "integer",
          "description": "Reports of target drug WITH target event",
          "required": true
        },
        {
          "name": "b",
          "type": "integer",
          "description": "Reports of target drug WITHOUT target event",
          "required": true
        },
        {
          "name": "c",
          "type": "integer",
          "description": "Reports of other drugs WITH target event",
          "required": true
        },
        {
          "name": "d",
          "type": "integer",
          "description": "Reports of other drugs WITHOUT target event",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "method": {
            "type": "string",
            "description": "Evans 2001 PRR criteria"
          },
          "prr": {
            "type": "number",
            "description": "Proportional Reporting Ratio"
          },
          "ci_95_lower": {
            "type": "number",
            "description": "Lower bound 95% confidence interval"
          },
          "ci_95_upper": {
            "type": "number",
            "description": "Upper bound 95% confidence interval"
          },
          "drug_reporting_rate": {
            "type": "number",
            "description": "Drug-specific reporting rate"
          },
          "background_rate": {
            "type": "number",
            "description": "Background reporting rate"
          },
          "chi_square": {
            "type": "number",
            "description": "Chi-squared test statistic"
          },
          "case_count": {
            "type": "number",
            "description": "Number of target drug-event reports (a)"
          },
          "signal": {
            "type": "boolean",
            "description": "True if PRR>=2, chi2>=4, N>=3"
          },
          "signal_criteria": {
            "type": "object",
            "description": "Individual signal criteria evaluation"
          },
          "contingency_table": {
            "type": "object",
            "description": "2x2 table {a, b, c, d, N}"
          },
          "reference": {
            "type": "string",
            "description": "Citation"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
