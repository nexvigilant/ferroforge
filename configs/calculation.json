          "required": true
        },
        {
          "name": "reappeared_on_rechallenge",
          "type": "string",
          "description": "Did the reaction reappear on rechallenge? (yes/no/not_done)",
          "required": true
        },
        {
          "name": "alternative_causes",
          "type": "boolean",
          "description": "Are there alternative causes that could have caused the reaction?",
          "required": true
        },
        {
          "name": "placebo_reaction",
          "type": "string",
