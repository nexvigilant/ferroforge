{
  "domain": "recalls-rappels.canada.ca",
  "url_pattern": "/*",
  "title": "Health Canada Drug Safety",
  "description": "Canadian drug recalls, safety reviews, adverse reaction database, and risk communications from Health Canada",
  "tools": [
    {
      "name": "search-recalls",
      "description": "Search Health Canada drug and health product recalls",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        },
        {
          "name": "limit",
          "type": "int",
          "description": "Maximum results to return",
          "required": false,
          "default": "25"
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-safety-reviews",
