{
  "domain": "cartography.nexvigilant.com",
  "url_pattern": "/*",
  "title": "Cartography Device",
  "description": "Navigate the stars — shows where NexVigilant is, where it's going, and the path to get there",
  "tools": [
    {
      "name": "chart",
      "description": "Full cartography — position, heading, and next action in one call. The base computer.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "chart": {
            "type": "object",
            "description": "Complete navigation chart"
          },
          "measured": {
            "type": "string",
            "description": "ISO timestamp of measurement"
          },
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": ["chart", "measured", "status"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-position",
      "description": "Where are we right now — all surfaces, ring health, connectivity edges, mission",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "position": {
            "type": "object",
            "description": "Current position across all surfaces"
          },
          "measured": {
            "type": "string",
            "description": "ISO timestamp"
          },
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": ["position", "measured", "status"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-heading",
      "description": "Where we're going — deadlines, strategy moves, bottlenecks, days remaining per gate",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "heading": {
            "type": "object",
            "description": "Strategic heading with deadlines and moves"
          },
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": ["heading", "status"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-next-action",
      "description": "The single most important thing to do right now — next gate, bottleneck, directive",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "next_action": {
            "type": "object",
            "description": "The next action to take"
          },
          "guidance": {
            "type": "string",
            "description": "One-sentence navigation guidance"
          },
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": ["guidance", "status"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "scripts/cartography_proxy.py"
}
