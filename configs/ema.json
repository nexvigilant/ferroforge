{
  "domain": "www.ema.europa.eu",
  "url_pattern": "/*",
  "title": "European Medicines Agency",
  "description": "EU regulatory data \u2014 EPARs, safety signals, referrals, and medicine information",
  "proxy": "scripts/ema_proxy.py",
  "tools": [
    {
      "name": "search-medicines",
      "description": "Search EU-authorised medicines by name, active substance, or therapeutic area",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Medicine name or active substance",
          "required": true
        },
        {
          "name": "therapeutic_area",
          "type": "string",
          "description": "Therapeutic area filter",
          "required": false
        },
        {
          "name": "authorisation_status",
          "type": "string",
          "description": "Status: authorised, withdrawn, refused",
          "required": false
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will query EMA medicines database via public search API.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      }
    },
    {
      "name": "get-epar",
      "description": "Get European Public Assessment Report summary for a medicine",
      "parameters": [
        {
          "name": "medicine_name",
          "type": "string",
          "description": "Medicine name",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will extract EPAR summary from EMA product page.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-safety-signals",
      "description": "Get PRAC safety signal assessments",
      "parameters": [
        {
          "name": "substance",
          "type": "string",
          "description": "Active substance name",
          "required": false
        },
        {
          "name": "year",
          "type": "integer",
          "description": "Year of assessment",
          "required": false
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will parse PRAC signal assessment list from EMA signal management page.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-referral",
      "description": "Get details of an Article 31/20 referral procedure",
      "parameters": [
        {
          "name": "substance",
          "type": "string",
          "description": "Active substance under referral",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-psur-assessment",
      "description": "Get Periodic Safety Update Report assessment outcome",
      "parameters": [
        {
          "name": "substance",
          "type": "string",
          "description": "Active substance",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-rmp-summary",
      "description": "Get Risk Management Plan summary for a medicine",
      "parameters": [
        {
          "name": "medicine_name",
          "type": "string",
          "description": "Medicine name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    }
  ]
}
