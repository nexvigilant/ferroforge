{
  "domain": "rxnav.nlm.nih.gov",
  "url_pattern": "/*",
  "title": "RxNav Drug Nomenclature",
  "description": "NLM RxNorm navigation \u2014 drug names, ingredients, NDCs, and interaction checking",
  "tools": [
    {
      "name": "get-rxcui",
      "description": "Get RxNorm Concept Unique Identifier for a drug name",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "drug_name": {
            "type": "string"
          },
          "rxcui": {
            "type": "string"
          },
          "all_rxcuis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "properties": {
            "type": "object"
          }
        },
        "required": [
          "status",
          "rxcui"
        ]
      }
    },
    {
      "name": "search-drugs",
      "description": "Search RxNorm for drugs by approximate name match",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Drug name search",
          "required": true
        },
        {
          "name": "max_entries",
          "type": "integer",
          "description": "Max results",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "query": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-interactions",
      "description": "Get drug-drug interactions for a list of drugs",
      "parameters": [
        {
          "name": "rxcuis",
          "type": "string",
          "description": "Plus-separated or comma-separated RxCUI list",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "interactions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-ingredients",
      "description": "Get active ingredients for a drug product",
      "parameters": [
        {
          "name": "rxcui",
          "type": "string",
          "description": "RxCUI identifier",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "rxcui": {
            "type": "string"
          },
          "ingredients": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-ndc",
      "description": "Get NDC codes for a drug product",
      "parameters": [
        {
          "name": "rxcui",
          "type": "string",
          "description": "RxCUI identifier",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "rxcui": {
            "type": "string"
          },
          "ndcs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-drug-classes",
      "description": "Get pharmacologic and therapeutic drug classes",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "rxcui": {
            "type": "string"
          },
          "classes": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    }
  ],
  "proxy": "scripts/rxnav_proxy.py"
}
