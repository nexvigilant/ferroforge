{
  "domain": "ich.org",
  "url_pattern": "/*",
  "title": "ICH Guidelines",
  "description": "International Council for Harmonisation \u2014 regulatory guidelines for pharmaceuticals",
  "proxy": "scripts/ich_proxy.py",
  "tools": [
    {
      "name": "search-guidelines",
      "description": "Search ICH guidelines by topic, code, or keyword",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query (e.g., 'E2E pharmacovigilance planning')",
          "required": true
        },
        {
          "name": "category",
          "type": "string",
          "description": "Guideline category: Q (Quality), S (Safety), E (Efficacy), M (Multidisciplinary)",
          "required": false
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will search ICH guidelines database for matching documents.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-guideline",
      "description": "Get ICH guideline summary and current step by code",
      "parameters": [
        {
          "name": "code",
          "type": "string",
          "description": "ICH code (e.g., E2A, E2B, E2C, E2D, E2E, S7B, M1)",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will extract guideline metadata, current step, and implementation dates from ICH database.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "code": {
            "type": "string",
            "description": "ICH guideline code (e.g., E2A, E2B)"
          },
          "description": {
            "type": "string",
            "description": "Guideline description and content"
          },
          "implementation_notes": {
            "type": "string",
            "description": "Implementation guidance"
          },
          "data_source": {
            "type": "string",
            "description": "Source attribution"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-pv-guidelines",
      "description": "Get all pharmacovigilance-related guidelines (E2x series)",
      "parameters": [],
      "stub_response": "{\"guidelines\": [\"E2A: Clinical Safety Data Management\", \"E2B(R3): ICSRs Electronic Transmission\", \"E2C(R2): PSURs\", \"E2D: Post-Approval Safety Data Management\", \"E2E: Pharmacovigilance Planning\", \"E2F: Development Safety Update Report\"], \"status\": \"stub\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "count": {
            "type": "integer",
            "description": "Number of guidelines"
          },
          "guidelines": {
            "type": "array",
            "description": "PV-relevant ICH guidelines"
          },
          "data_source": {
            "type": "string",
            "description": "Source attribution"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
