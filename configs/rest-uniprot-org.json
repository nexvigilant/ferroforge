{
  "domain": "rest.uniprot.org",
  "url_pattern": "/*",
  "title": "UniProt Protein Knowledge Base",
  "description": "Protein sequence, function, variants, and disease associations from UniProt",
  "tools": [
    {
      "name": "search-proteins",
      "description": "Search UniProt for proteins by name, gene, or organism",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-protein",
      "description": "Get full protein entry with function, subcellular location, and GO terms",
      "parameters": [
        {
          "name": "accession",
          "type": "string",
          "description": "Accession",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-protein-variants",
      "description": "Get known sequence variants and disease associations",
      "parameters": [
        {
          "name": "accession",
          "type": "string",
          "description": "Accession",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-protein-interactions",
      "description": "Get protein-protein interactions",
      "parameters": [
        {
          "name": "accession",
          "type": "string",
          "description": "Accession",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-protein-disease",
      "description": "Get disease involvement for a protein",
      "parameters": [
        {
          "name": "accession",
          "type": "string",
          "description": "Accession",
