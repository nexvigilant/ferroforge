  "title": "Combinatorics — Dudeney-Derived Algorithms",
  "description": "Catalan numbers, derangements, cycle decomposition, Josephus problem, grid paths, binomial/multinomial coefficients, and linear extensions. Pure Rust via nexcore-combinatorics.",
  "proxy": "rust-native",
  "tools": [
    { "name": "catalan", "description": "Compute the nth Catalan number C(n).", "parameters": [{"name":"n","type":"integer","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "catalan-table", "description": "Get the first 20 Catalan numbers as a lookup table.", "parameters": [], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "cycle-decomposition", "description": "Decompose a permutation into disjoint cycles.", "parameters": [{"name":"permutation","type":"array","description":"Permutation as array of indices","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "min-transpositions", "description": "Compute minimum transpositions to sort a permutation.", "parameters": [{"name":"permutation","type":"array","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "derangement", "description": "Compute D(n), the number of derangements of n elements.", "parameters": [{"name":"n","type":"integer","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "derangement-probability", "description": "Probability D(n)/n! that a random permutation is a derangement (converges to 1/e).", "parameters": [{"name":"n","type":"integer","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "grid-paths", "description": "Count monotone lattice paths from (0,0) to (m,n).", "parameters": [{"name":"m","type":"integer","required":true},{"name":"n","type":"integer","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "binomial", "description": "Compute binomial coefficient C(n,k).", "parameters": [{"name":"n","type":"integer","required":true},{"name":"k","type":"integer","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "multinomial", "description": "Compute multinomial coefficient from group lengths.", "parameters": [{"name":"lengths","type":"array","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "josephus", "description": "Compute Josephus survivor position (0-indexed) for n people, every kth eliminated.", "parameters": [{"name":"n","type":"integer","required":true},{"name":"k","type":"integer","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "elimination-order", "description": "Full Josephus elimination order.", "parameters": [{"name":"n","type":"integer","required":true},{"name":"k","type":"integer","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} },
    { "name": "linear-extensions", "description": "Count linear extensions for independent chains.", "parameters": [{"name":"chain_lengths","type":"array","required":true}], "outputSchema":{"type":"object","properties":{"status":{"type":"string"}},"required":["status"]}, "annotations":{"readOnlyHint":true,"destructiveHint":false} }
  ]
}
