{
  "domain": "eudravigilance.ema.europa.eu",
  "url_pattern": "/*",
  "title": "EudraVigilance",
  "description": "EU pharmacovigilance database \u2014 Individual Case Safety Reports and signal detection",
  "proxy": "scripts/eudravigilance_proxy.py",
  "tools": [
    {
      "name": "search-reports",
      "description": "Search EudraVigilance line listings by substance and reaction",
      "parameters": [
        {
          "name": "substance",
          "type": "string",
          "description": "Active substance name",
          "required": true
        },
        {
          "name": "reaction",
          "type": "string",
          "description": "MedDRA preferred term",
          "required": false
        },
        {
          "name": "serious",
          "type": "boolean",
          "description": "Filter to serious cases",
          "required": false
        },
        {
          "name": "age_group",
          "type": "string",
          "description": "Age group filter",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      }
    },
    {
      "name": "get-signal-summary",
      "description": "Get disproportionality signal summary (ROR) for a substance-reaction pair",
      "parameters": [
        {
          "name": "substance",
          "type": "string",
          "description": "Active substance",
          "required": true
        },
        {
          "name": "reaction",
          "type": "string",
          "description": "MedDRA PT",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-case-counts",
      "description": "Get total ICSR counts by substance with breakdown by seriousness and outcome",
      "parameters": [
        {
          "name": "substance",
          "type": "string",
          "description": "Active substance",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-geographical-distribution",
      "description": "Get case count distribution by EEA country",
      "parameters": [
        {
          "name": "substance",
          "type": "string",
          "description": "Active substance",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    }
  ]
}
