{
  "domain": "edit-distance.nexvigilant.com",
  "private": false,
  "copyright": "\u00a9 2026 NexVigilant, LLC.",
  "title": "Edit Distance \u2014 String Similarity Algorithms",
  "description": "Levenshtein, Damerau-Levenshtein, and LCS distance computation for fuzzy drug name matching, MedDRA term comparison, and general string similarity. Supports single-pair and batch operations with traceback. Pure Rust via nexcore-edit-distance.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "compute",
      "description": "Compute edit distance between two strings. Algorithms: levenshtein (default), damerau (transposition-aware), lcs (longest common subsequence). Returns distance and normalized similarity (0-1).",
      "parameters": [
        {
          "name": "source",
          "type": "string",
          "description": "Source string",
          "required": true
        },
        {
          "name": "target",
          "type": "string",
          "description": "Target string",
          "required": true
        },
        {
          "name": "algorithm",
          "type": "string",
          "description": "Algorithm: levenshtein (default), damerau, lcs",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "distance": {
            "type": "number"
          },
          "similarity": {
            "type": "number"
          },
          "algorithm": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "similarity",
      "description": "Check if two strings meet a similarity threshold. Returns similarity score and pass/fail against threshold. Useful for drug name matching gates.",
      "parameters": [
        {
          "name": "source",
          "type": "string",
          "description": "Source string",
          "required": true
        },
        {
          "name": "target",
          "type": "string",
          "description": "Target string",
          "required": true
        },
        {
          "name": "threshold",
          "type": "number",
          "description": "Minimum similarity to pass (default 0.8)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "similarity": {
            "type": "number"
          },
          "threshold": {
            "type": "number"
          },
          "passes": {
            "type": "boolean"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "traceback",
      "description": "Compute edit distance with full operation traceback showing the sequence of insertions, deletions, and substitutions to transform source into target.",
      "parameters": [
        {
          "name": "source",
          "type": "string",
          "description": "Source string",
          "required": true
        },
        {
          "name": "target",
          "type": "string",
          "description": "Target string",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "distance": {
            "type": "number"
          },
          "operations": {
            "type": "array"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "batch",
      "description": "Compare a query string against multiple candidates. Returns ranked matches by similarity with optional threshold and limit filters. Ideal for fuzzy search over drug names or ADR terms.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Query string to match against candidates",
          "required": true
        },
        {
          "name": "candidates",
          "type": "array",
          "description": "Array of candidate strings to compare",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum results to return",
          "required": false
        },
        {
          "name": "min_similarity",
          "type": "number",
          "description": "Minimum similarity threshold (0-1)",
          "required": false
        },
        {
          "name": "algorithm",
          "type": "string",
          "description": "Algorithm: levenshtein (default), damerau, lcs",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "matches": {
            "type": "array"
          },
          "total_candidates": {
            "type": "integer"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "url_pattern": "/*"
}
