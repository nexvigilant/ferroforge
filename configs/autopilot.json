{
  "domain": "autopilot.nexvigilant.com",
  "url_pattern": "/*",
  "title": "PV Autopilot \u2014 Autonomous Drug Safety Intelligence",
  "description": "One tool call, complete PV intelligence. Give a drug name and mission, get a full execution plan chaining Station tools into autonomous workflows. Includes infrastructure gap scanning and Claude Code terminal integration.",
  "tools": [
    {
      "name": "run",
      "description": "Run PV Autopilot for a drug. Returns execution plan chaining 6-30 Station tools. Missions: signal-scan, launch-readiness, competitive-intel, label-audit, full-profile, claude-terminal.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Drug name (generic)",
          "required": true
        },
        {
          "name": "mission",
          "type": "string",
          "description": "Mission: signal-scan, launch-readiness, competitive-intel, label-audit, full-profile",
          "required": false
        },
        {
          "name": "comparators",
          "type": "array",
          "description": "Competitor drugs for competitive-intel",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "drug": {
            "type": "string"
          },
          "plan": {
            "type": "object",
            "properties": {
              "mission": { "type": "string" },
              "steps": { "type": "array", "items": { "type": "object" } },
              "estimated_tool_calls": { "type": "integer" },
              "estimated_duration_s": { "type": "integer" }
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "missions",
      "description": "List all PV Autopilot missions with descriptions and estimated execution times.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "missions": {
            "type": "array"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "scan-gaps",
      "description": "Scan for infrastructure wiring gaps between configs, handlers, and lib.rs.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "gaps": {
            "type": "array"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "claude-terminal",
      "description": "Launch Claude Code in NexVigilant Terminal with Station MCP pre-configured. Returns a 4-step execution plan: verify binary → check Station health → load tool catalog → report readiness.",
      "parameters": [
        {
          "name": "working_dir",
          "type": "string",
          "description": "Working directory for Claude Code session (default: home)",
          "required": false
        },
        {
          "name": "args",
          "type": "array",
          "description": "Extra CLI arguments for Claude Code (e.g. ['--verbose'])",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "plan": {
            "type": "object",
            "properties": {
              "mission": { "type": "string", "enum": ["claude-terminal"] },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "step": { "type": "integer" },
                    "action": { "type": "string" },
                    "tool": { "type": "string" },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          },
          "station_health": { "type": "object" },
          "tool_count": { "type": "integer" },
          "claude_ready": { "type": "boolean" }
        },
        "required": ["status"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "fix-all-gaps",
      "description": "Attempt to fix all detected wiring gaps. Requires authentication.",
      "private": true,
      "parameters": [
        {
          "name": "dry_run",
          "type": "boolean",
          "description": "If true, only report what would be fixed.",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "fixed_count": {
            "type": "integer"
          },
          "fixes": {
            "type": "array",
            "items": { "type": "object" }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true
      }
    }
  ],
  "proxy": "rust-native"
}
