{
  "domain": "www.gov.uk",
  "url_pattern": "/*",
  "title": "MHRA UK Drug Safety",
  "description": "UK Medicines and Healthcare products Regulatory Agency \u2014 Yellow Card adverse reaction reports, safety updates, and drug alerts",
  "tools": [
    {
      "name": "search-yellow-card-reports",
      "description": "Search MHRA Yellow Card adverse reaction reports",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        },
        {
          "name": "reaction",
          "type": "str",
          "description": "Adverse reaction (MedDRA preferred term)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
