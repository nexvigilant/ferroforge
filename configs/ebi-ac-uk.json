{
  "domain": "www.ebi.ac.uk",
  "url_pattern": "/*",
  "title": "ChEMBL Bioactivity Database",
  "description": "Drug bioactivity data, targets, mechanisms of action, and assay results from ChEMBL at EMBL-EBI",
  "tools": [
    {
      "name": "search-compounds",
      "description": "Search ChEMBL for compounds by name, synonym, or identifier",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-compound",
      "description": "Get compound details including structure, properties, and clinical phase",
      "parameters": [
        {
          "name": "chembl_id",
          "type": "string",
          "description": "Chembl Id",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-compound-bioactivities",
      "description": "Get bioactivity measurements (IC50, EC50, Ki) for a compound",
      "parameters": [
        {
          "name": "chembl_id",
          "type": "string",
          "description": "Chembl Id",
          "required": true
        },
        {
          "name": "limit",
          "type": "int",
          "description": "Maximum results to return",
          "required": false,
          "default": "25"
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-drug-mechanisms",
