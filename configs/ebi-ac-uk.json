      "parameters": [
        {
          "name": "chembl_id",
          "type": "string",
          "description": "Chembl Id",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-targets",
      "description": "Search drug targets by name, gene symbol, or organism",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
