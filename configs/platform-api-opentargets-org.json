{
  "domain": "platform-api.opentargets.org",
  "url_pattern": "/*",
  "title": "Open Targets Platform",
  "description": "Target-disease associations, drug evidence, and genetic links from Open Targets",
  "tools": [
    {
      "name": "search-targets",
      "description": "Search for drug targets by gene name or protein",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-diseases",
      "description": "Search diseases by name or EFO identifier",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-associations",
      "description": "Get disease associations for a target with evidence scores",
      "parameters": [
        {
          "name": "target_id",
          "type": "string",
          "description": "Target Id",
          "required": true
        },
        {
          "name": "limit",
          "type": "int",
          "description": "Maximum results to return",
          "required": false,
          "default": "25"
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-drug-evidence",
      "description": "Get drug evidence linking a target to a disease",
      "parameters": [
        {
          "name": "target_id",
          "type": "string",
          "description": "Target Id",
          "required": true
        },
        {
          "name": "disease_id",
          "type": "string",
          "description": "Disease Id",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-target-safety",
      "description": "Get known safety effects and toxicity for a target",
      "parameters": [
        {
          "name": "target_id",
          "type": "string",
          "description": "Target Id",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
