{
  "domain": "go.drugbank.com",
  "url_pattern": "/*",
  "title": "DrugBank",
  "description": "Comprehensive drug data \u2014 pharmacology, interactions, targets, and pathways",
  "proxy": "scripts/drugbank_proxy.py",
  "tools": [
    {
      "name": "get-drug-info",
      "description": "Get comprehensive drug profile including pharmacology and mechanism",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will extract drug profile from DrugBank public page.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "drug_name": {
            "type": "string",
            "description": "Resolved drug name"
          },
          "pubchem_cid": {
            "type": "integer",
            "description": "PubChem compound ID"
          },
          "molecular_formula": {
            "type": "string",
            "description": "Molecular formula"
          },
          "molecular_weight": {
            "type": "number",
            "description": "Molecular weight"
          },
          "canonical_smiles": {
            "type": "string",
            "description": "SMILES notation"
          },
          "iupac_name": {
            "type": "string",
            "description": "IUPAC systematic name"
          },
          "description": {
            "type": "string",
            "description": "Drug description"
          },
          "regulatory": {
            "type": "object",
            "description": "FDA regulatory info (brand, generic, manufacturer, route)"
          },
          "pharmacological_classes": {
            "type": "object",
            "description": "EPC and MOA classifications"
          },
          "sources": {
            "type": "array",
            "description": "Data source attributions"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-interactions",
      "description": "Get drug-drug interactions with mechanism descriptions",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will parse interaction table from DrugBank drug page.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "drug_name": {
            "type": "string",
            "description": "Query drug name"
          },
          "label_drug_interactions": {
            "type": "string",
            "description": "Drug interaction section from product label"
          },
          "faers_co_reported_drugs": {
            "type": "array",
            "description": "Top co-reported drugs from FAERS"
          },
          "sources": {
            "type": "array",
            "description": "Data source attributions"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-pharmacology",
      "description": "Get pharmacokinetics and pharmacodynamics data",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "drug_name": {
            "type": "string",
            "description": "Query drug name"
          },
          "mechanism_of_action": {
            "type": "string",
            "description": "Mechanism of action from label"
          },
          "pharmacodynamics": {
            "type": "string",
            "description": "Pharmacodynamic properties"
          },
          "pharmacokinetics": {
            "type": "string",
            "description": "PK properties"
          },
          "clinical_pharmacology": {
            "type": "string",
            "description": "Clinical pharmacology section"
          },
          "pharmacological_classes": {
            "type": "object",
            "description": "Drug classifications"
          },
          "sources": {
            "type": "array",
            "description": "Data source attributions"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-targets",
      "description": "Get drug targets (enzymes, transporters, carriers)",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "drug_name": {
            "type": "string",
            "description": "Query drug name"
          },
          "gene_targets": {
            "type": "array",
            "description": "Gene targets with activity and type"
          },
          "total_gene_targets": {
            "type": "integer",
            "description": "Total gene targets found"
          },
          "pharmacological_classes": {
            "type": "object",
            "description": "Drug classifications"
          },
          "sources": {
            "type": "array",
            "description": "Data source attributions"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-adverse-effects",
      "description": "Get known adverse effects with frequency data",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "drug_name": {
            "type": "string",
            "description": "Query drug name"
          },
          "label_adverse_reactions": {
            "type": "string",
            "description": "Adverse reactions section from product label"
          },
          "boxed_warning": {
            "type": "string",
            "description": "Boxed warning if present"
          },
          "faers_top_reactions": {
            "type": "array",
            "description": "Top reported reactions from FAERS with counts"
          },
          "sources": {
            "type": "array",
            "description": "Data source attributions"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-classification",
      "description": "Get drug classification \u2014 pharmacologic class, mechanism of action, ATC codes, product type, route, and dosage form",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | not_found"
          },
          "drug_name": {
            "type": "string"
          },
          "openfda_classification": {
            "type": "object"
          },
          "pubchem_classification": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-contraindications",
      "description": "Get contraindications, boxed warnings, warnings/precautions, pregnancy, pediatric, and geriatric use information",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | not_found"
          },
          "drug_name": {
            "type": "string"
          },
          "has_boxed_warning": {
            "type": "boolean"
          },
          "sections_found": {
            "type": "integer"
          },
          "contraindications": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ]
}
