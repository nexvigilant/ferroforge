{
  "domain": "go.drugbank.com",
  "url_pattern": "/*",
  "title": "DrugBank",
  "description": "Comprehensive drug data \u2014 pharmacology, interactions, targets, and pathways",
  "proxy": "scripts/drugbank_proxy.py",
  "tools": [
    {
      "name": "get-drug-info",
      "description": "Get comprehensive drug profile including pharmacology and mechanism",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will extract drug profile from DrugBank public page.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-interactions",
      "description": "Get drug-drug interactions with mechanism descriptions",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will parse interaction table from DrugBank drug page.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-pharmacology",
      "description": "Get pharmacokinetics and pharmacodynamics data",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-targets",
      "description": "Get drug targets (enzymes, transporters, carriers)",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-adverse-effects",
      "description": "Get known adverse effects with frequency data",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-classification",
      "description": "Get drug classification — pharmacologic class, mechanism of action, ATC codes, product type, route, and dosage form",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | not_found"
          },
          "drug_name": {
            "type": "string"
          },
          "openfda_classification": {
            "type": "object"
          },
          "pubchem_classification": {
            "type": "object"
          }
        },
        "required": ["status"]
      }
    },
    {
      "name": "get-contraindications",
      "description": "Get contraindications, boxed warnings, warnings/precautions, pregnancy, pediatric, and geriatric use information",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | not_found"
          },
          "drug_name": {
            "type": "string"
          },
          "has_boxed_warning": {
            "type": "boolean"
          },
          "sections_found": {
            "type": "integer"
          },
          "contraindications": {
            "type": "object"
          }
        },
        "required": ["status"]
      }
    }
  ]
}
