{
  "domain": "www.fda.gov",
  "url_pattern": "/safety/*",
  "title": "FDA Safety Communications",
  "description": "FDA drug safety communications, MedWatch alerts, and safety labeling changes",
  "proxy": "scripts/fda_safety_proxy.py",
  "tools": [
    {
      "name": "search-safety-communications",
      "description": "Search FDA drug safety communications by drug or topic",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Drug name or safety topic",
          "required": true
        },
        {
          "name": "year",
          "type": "integer",
          "description": "Year filter",
          "required": false
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will search FDA safety communications archive.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      }
    },
    {
      "name": "get-medwatch-alerts",
      "description": "Get recent MedWatch safety alerts",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name filter",
          "required": false
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Number of recent alerts",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-boxed-warning",
      "description": "Get current boxed warning text for a drug",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-safety-labeling-changes",
      "description": "Get recent safety-related labeling changes (SLCs)",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": false
        },
        {
          "name": "section",
          "type": "string",
          "description": "Label section (Warnings, Contraindications, Adverse Reactions)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    }
  ]
}
