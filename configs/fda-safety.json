{
  "domain": "www.fda.gov",
  "url_pattern": "/safety/*",
  "title": "FDA Safety Communications",
  "description": "FDA drug safety communications, MedWatch alerts, and safety labeling changes",
  "proxy": "scripts/fda_safety_proxy.py",
  "tools": [
    {
      "name": "search-safety-communications",
      "description": "Search FDA drug safety communications by drug or topic",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Drug name or safety topic",
          "required": true
        },
        {
          "name": "year",
          "type": "integer",
          "description": "Year filter",
          "required": false
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will search FDA safety communications archive.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      }
    },
    {
      "name": "get-medwatch-alerts",
      "description": "Get recent MedWatch safety alerts",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name filter",
          "required": false
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Number of recent alerts",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-boxed-warning",
      "description": "Get current boxed warning text for a drug",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-safety-labeling-changes",
      "description": "Get recent safety-related labeling changes (SLCs)",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": false
        },
        {
          "name": "section",
          "type": "string",
          "description": "Label section (Warnings, Contraindications, Adverse Reactions)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-recall-classification",
      "description": "Get recall classification breakdown — Class I (serious/death), Class II (temporary), Class III (unlikely harm)",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "data": {
            "type": "object",
            "properties": {
              "total_recalls": { "type": "integer" },
              "by_classification": { "type": "object" },
              "by_status": { "type": "object" },
              "by_voluntary_mandated": { "type": "object" }
            }
          }
        },
        "required": ["status"]
      }
    },
    {
      "name": "get-serious-outcomes",
      "description": "Get serious outcome distribution from FAERS — death, hospitalization, life-threatening, disability",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (generic)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "data": {
            "type": "object",
            "properties": {
              "total_reports": { "type": "integer" },
              "serious_reports": { "type": "integer" },
              "serious_percentage": { "type": "number" },
              "outcome_breakdown": { "type": "object" }
            }
          }
        },
        "required": ["status"]
      }
    },
    {
      "name": "get-rems-info",
      "description": "Get REMS (Risk Evaluation and Mitigation Strategy) information — medication guides, ETASU, communication plans",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "data": {
            "type": "object",
            "properties": {
              "has_rems": { "type": "boolean" },
              "labels_with_rems": { "type": "integer" },
              "results": {
                "type": "array",
                "items": { "type": "object" }
              }
            }
          }
        },
        "required": ["status"]
      }
    }
  ]
}
