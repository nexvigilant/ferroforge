{
  "domain": "www.fda.gov",
  "url_pattern": "/safety/*",
  "title": "FDA Safety Communications",
  "description": "FDA drug safety communications, MedWatch alerts, and safety labeling changes",
  "tools": [
    {
      "name": "search-safety-communications",
      "description": "Search FDA drug safety communications by drug or topic",
      "parameters": [
        {"name": "query", "type": "string", "description": "Drug name or safety topic", "required": true},
        {"name": "year", "type": "integer", "description": "Year filter", "required": false}
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will search FDA safety communications archive.\"}"
    },
    {
      "name": "get-medwatch-alerts",
      "description": "Get recent MedWatch safety alerts",
      "parameters": [
        {"name": "drug_name", "type": "string", "description": "Drug name filter", "required": false},
        {"name": "limit", "type": "integer", "description": "Number of recent alerts", "required": false}
      ]
    },
    {
      "name": "get-boxed-warning",
      "description": "Get current boxed warning text for a drug",
      "parameters": [
        {"name": "drug_name", "type": "string", "description": "Drug name", "required": true}
      ]
    },
    {
      "name": "get-safety-labeling-changes",
      "description": "Get recent safety-related labeling changes (SLCs)",
      "parameters": [
        {"name": "drug_name", "type": "string", "description": "Drug name", "required": false},
        {"name": "section", "type": "string", "description": "Label section (Warnings, Contraindications, Adverse Reactions)", "required": false}
      ]
    }
  ]
}
