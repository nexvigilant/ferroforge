{
  "domain": "www.gov.br/anvisa",
  "description": "ANVISA (Ag\u00eancia Nacional de Vigil\u00e2ncia Sanit\u00e1ria) \u2014 Brazil's health surveillance agency. Drug registrations, safety alerts, pharmacovigilance data, and regulatory actions for the Brazilian market (largest in Latin America).",
  "tools": [
    {
      "name": "search-drug-registry",
      "description": "Pesquisar medicamentos no registro da ANVISA por nome, princ\u00edpio ativo, ou empresa. Search Brazil's drug registry by name, active ingredient, or company.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Nome do medicamento ou princ\u00edpio ativo / Drug name or active ingredient",
          "required": true
        },
        {
          "name": "empresa",
          "type": "string",
          "description": "Nome da empresa / Company name",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "registro": {
                  "type": "string"
                },
                "nome_comercial": {
                  "type": "string"
                },
                "principio_ativo": {
                  "type": "string"
                },
                "empresa": {
                  "type": "string"
                },
                "forma_farmaceutica": {
                  "type": "string"
                },
                "classe_terapeutica": {
                  "type": "string"
                },
                "vencimento_registro": {
                  "type": "string"
                }
              }
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-safety-alerts",
      "description": "Obter alertas de seguran\u00e7a e informes de farmacovigil\u00e2ncia da ANVISA. Get safety alerts and pharmacovigilance bulletins issued by Brazil's health authority.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Nome do medicamento / Drug name",
          "required": false
        },
        {
          "name": "year",
          "type": "integer",
          "description": "Ano do alerta / Alert year",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "alerts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "string"
                },
                "titulo": {
                  "type": "string"
                },
                "tipo": {
                  "type": "string"
                },
                "principio_ativo": {
                  "type": "string"
                },
                "acao_regulatoria": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-notivisa-reports",
      "description": "Obter dados do sistema NOTIVISA \u2014 sistema de notifica\u00e7\u00e3o de eventos adversos e queixas t\u00e9cnicas do Brasil. Get data from Brazil's adverse event and technical complaint notification system.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Nome do medicamento / Drug name",
          "required": true
        },
        {
          "name": "reaction",
          "type": "string",
          "description": "Rea\u00e7\u00e3o adversa pesquisada / Adverse reaction query",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "drug": {
            "type": "string"
          },
          "total_notifications": {
            "type": "integer"
          },
          "classification": {
            "type": "object",
            "properties": {
              "grave": {
                "type": "integer"
              },
              "nao_grave": {
                "type": "integer"
              },
              "obito": {
                "type": "integer"
              }
            }
          },
          "top_reactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reaction": {
                  "type": "string"
                },
                "count": {
                  "type": "integer"
                }
              }
            }
          },
          "source": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-recall-actions",
      "description": "Obter recolhimentos de medicamentos determinados pela ANVISA. Get drug recalls and market withdrawals ordered by Brazil's health authority.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Nome do medicamento ou empresa / Drug or company name",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "recalls": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "string"
                },
                "medicamento": {
                  "type": "string"
                },
                "empresa": {
                  "type": "string"
                },
                "motivo": {
                  "type": "string"
                },
                "lote": {
                  "type": "string"
                },
                "resolucao": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-regulatory-classification",
      "description": "Obter a classifica\u00e7\u00e3o regulat\u00f3ria de um medicamento no Brasil (refer\u00eancia, similar, gen\u00e9rico, biol\u00f3gico). Get a drug's regulatory classification in Brazil.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Nome do medicamento / Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "drug": {
            "type": "string"
          },
          "categoria": {
            "type": "string"
          },
          "classification": {
            "type": "string"
          },
          "description_pt": {
            "type": "string"
          },
          "description_en": {
            "type": "string"
          },
          "prescricao_obrigatoria": {
            "type": "boolean"
          },
          "controlado": {
            "type": "boolean"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "url_pattern": "/*",
  "title": "anvisa",
  "proxy": "rust-native"
}
