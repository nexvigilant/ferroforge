{
  "domain": "voila.nexvigilant.com",
  "url_pattern": "/*",
  "title": "Voila Rendering",
  "description": "Notebook rendering, interactive dashboard deployment, and Voila server management",
  "tools": [
    {
      "name": "voila-list",
      "description": "List .ipynb files with metadata (kernel, size).",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "voila-render",
      "description": "Check if Voila can render a specific notebook. Returns render URL.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "voila-status",
      "description": "Check Voila extension status.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "rust-native"
}
