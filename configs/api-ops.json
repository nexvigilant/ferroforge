{
  "domain": "api-ops.nexvigilant.com",
  "url_pattern": "/*",
  "title": "API Operations",
  "description": "API health checks, route listing, and HTTP request handling",
  "tools": [
    {
      "name": "api-health",
      "description": "Get respiratory system health overview.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "api-list-routes",
      "description": "List available NexCore REST API routes",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "rust-native"
}
