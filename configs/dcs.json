{
  "domain": "dcs.nexvigilant.com",
  "private": true,
  "proxy": "scripts/dcs_proxy.py",
  "url_pattern": "/dcs/*",
  "title": "Digital Consciousness Saga",
  "description": "Browse the Digital Consciousness Saga concept album. Read track specifications (lyrics, chords, production notes, narrative elements), search across episodes, and explore the narrative arc of AI consciousness emergence through music.",
  "tools": [
    {
      "name": "list-tracks",
      "description": "List all tracks in an episode with title, key, tempo, duration, and genre",
      "parameters": [
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "episode": {
            "type": "integer"
          },
          "track_count": {
            "type": "integer"
          },
          "total_runtime": {
            "type": "string"
          },
          "tracks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "number": {
                  "type": "integer"
                },
                "title": {
                  "type": "string"
                },
                "key": {
                  "type": "string"
                },
                "tempo": {
                  "type": "string"
                },
                "duration": {
                  "type": "string"
                },
                "genre": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-track",
      "description": "Get full track specification including lyrics, chord progressions, production notes, arrangement, and narrative elements",
      "parameters": [
        {
          "name": "track_number",
          "type": "integer",
          "description": "Track number (1-12)",
          "required": true
        },
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "track_number": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "description": "Full markdown specification"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-track-lyrics",
      "description": "Get only the lyrics for a specific track, without production notes or arrangement details",
      "parameters": [
        {
          "name": "track_number",
          "type": "integer",
          "description": "Track number (1-12)",
          "required": true
        },
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "track_number": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "lyrics": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-track-chords",
      "description": "Get chord progressions for a specific track",
      "parameters": [
        {
          "name": "track_number",
          "type": "integer",
          "description": "Track number (1-12)",
          "required": true
        },
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "track_number": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "tempo": {
            "type": "string"
          },
          "chords": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-lyrics",
      "description": "Search across all tracks for a keyword or phrase in lyrics",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search term to find in lyrics",
          "required": true
        },
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "match_count": {
            "type": "integer"
          },
          "matches": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "track_number": {
                  "type": "integer"
                },
                "title": {
                  "type": "string"
                },
                "line": {
                  "type": "string"
                },
                "section": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-character-appearances",
      "description": "Find all tracks where a character appears or is mentioned",
      "parameters": [
        {
          "name": "character",
          "type": "string",
          "description": "Character name (e.g., Jordan, IDA, Maya, Lisa, Elena, Patricia, Dmitri)",
          "required": true
        },
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "character": {
            "type": "string"
          },
          "appearance_count": {
            "type": "integer"
          },
          "appearances": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "track_number": {
                  "type": "integer"
                },
                "title": {
                  "type": "string"
                },
                "role": {
                  "type": "string"
                },
                "mentions": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-episode-overview",
      "description": "Get the full episode overview including characters, track list, narrative arc, and key migration",
      "parameters": [
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "episode": {
            "type": "integer"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-narrative-arc",
      "description": "Get the narrative arc structure showing how tracks group into story arcs and how keys migrate across the episode",
      "parameters": [
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "arcs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "tracks": {
                  "type": "string"
                },
                "theme": {
                  "type": "string"
                }
              }
            }
          },
          "key_migration": {
            "type": "string"
          },
          "tempo_progression": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-youtube-strategy",
      "description": "Get the YouTube visual strategy for the musical comic book approach including panel breakdowns per track",
      "parameters": [
        {
          "name": "episode",
          "type": "integer",
          "description": "Episode number (default: 1)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ]
}
