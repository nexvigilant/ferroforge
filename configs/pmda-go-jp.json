      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        },
        {
          "name": "limit",
          "type": "int",
          "description": "Maximum results to return",
          "required": false,
          "default": "25"
        }
      ],
      "outputSchema": {
        "type": "object",
