{
  "domain": "www.pmda.go.jp",
  "url_pattern": "/*",
  "title": "PMDA Japan Pharmaceuticals",
  "description": "Japanese Pharmaceuticals and Medical Devices Agency \u2014 adverse drug reaction reports, safety information, and drug approvals",
  "tools": [
    {
      "name": "search-safety-information",
      "description": "Search PMDA safety communications and Dear Healthcare Professional letters",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-adverse-reactions",
