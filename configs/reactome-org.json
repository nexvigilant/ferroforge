{
  "domain": "reactome.org",
  "url_pattern": "/*",
  "title": "Reactome Biological Pathways",
  "description": "Curated biological pathway and reaction data from Reactome",
  "tools": [
    {
      "name": "search-pathways",
      "description": "Search pathways by name, gene, or keyword",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-pathway",
      "description": "Get pathway details by stable identifier",
      "parameters": [
        {
          "name": "pathway_id",
          "type": "string",
          "description": "Pathway Id",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
