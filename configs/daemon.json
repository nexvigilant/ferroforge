{
  "domain": "daemon.nexvigilant.com",
  "url_pattern": "/daemon/*",
  "title": "AIP Fleet Command",
  "copyright": "\u00a9 2026 NexVigilant, LLC.",
  "description": "Autonomous Intelligence Program fleet status. 10 AIPs across code health, microgram patrol, station watchdog, dependency scanning, knowledge decay, brain hygiene, skill entropy, hook health, git hygiene, and system synthesis.",
  "tools": [
    {
      "name": "get-work-queue",
      "description": "Get the current ranked work queue produced by the Development Daemon candidate scanner. Returns up to 10 candidates scored by Atomicity, Permanence, Unblock Power, Vision Alignment, and Ground-Clearing.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "urgency": {
                  "type": "number"
                },
                "composite": {
                  "type": "number"
                },
                "blast_radius": {
                  "type": "string"
                },
                "scope_hint": {
                  "type": "string"
                }
              }
            }
          },
          "count": {
            "type": "integer"
          },
          "last_scan": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-momentum",
      "description": "Get the Development Daemon momentum streak and recent completions. Shows how many consecutive tasks have been completed and the last 10 items.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "streak": {
            "type": "integer"
          },
          "completed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "skipped": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_scan": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-last-verdict",
      "description": "Get the last session's autopsy verdict. Shows whether the previous session fully demonstrated, partially demonstrated, or failed its proposition.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string"
          },
          "proposition": {
            "type": "string"
          },
          "lesson_count": {
            "type": "integer"
          },
          "pattern_count": {
            "type": "integer"
          },
          "session_id": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-daemon-status",
      "description": "Get the Development Daemon overall status: trigger enabled, next run time, scanner health, and system integration state.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "trigger_enabled": {
            "type": "boolean"
          },
          "next_run": {
            "type": "string"
          },
          "scanner_registered": {
            "type": "boolean"
          },
          "queue_age_seconds": {
            "type": "integer"
          },
          "streak": {
            "type": "integer"
          },
          "steps_live": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-system-health",
      "description": "Get the AIP-10 system health score (0-100, grade A-F). Composite of queue depth, sigma verdict rate, momentum streak, and last session outcome.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "health_score": {
            "type": "integer"
          },
          "grade": {
            "type": "string"
          },
          "sigma_pct": {
            "type": "number"
          },
          "streak": {
            "type": "integer"
          },
          "queue_depth": {
            "type": "integer"
          },
          "last_verdict": {
            "type": "string"
          },
          "total_sessions": {
            "type": "integer"
          },
          "timestamp": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-aip-inventory",
      "description": "List all 10 Autonomous Intelligence Programs with their type (remote/local), surface, and status.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "aips": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "surface": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                }
              }
            }
          },
          "total": {
            "type": "integer"
          },
          "remote_count": {
            "type": "integer"
          },
          "local_count": {
            "type": "integer"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "daemon_proxy.py"
}
