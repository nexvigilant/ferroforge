{
  "domain": "www.astrazeneca.com",
  "url_pattern": "/*",
  "title": "AstraZeneca PLC",
  "description": "AstraZeneca PLC pharmacovigilance intelligence \u2014 product portfolio, clinical pipeline, safety profile, recalls, and labeling changes",
  "proxy": "scripts/dispatch.py",
  "tools": [
    {
      "name": "get-portfolio",
      "description": "Get AstraZeneca PLC approved product portfolio \u2014 brand names, generics, routes, pharmacologic classes",
      "parameters": [
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results (default 25, max 100)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | not_found"
          },
          "company": {
            "type": "string"
          },
          "product_count": {
            "type": "integer"
          },
          "products": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-pipeline",
      "description": "Get AstraZeneca PLC clinical trial pipeline \u2014 active and recruiting trials by phase",
      "parameters": [
        {
          "name": "phase",
          "type": "string",
          "description": "Phase filter: PHASE1, PHASE2, PHASE3, PHASE4",
          "required": false
        },
        {
          "name": "condition",
          "type": "string",
          "description": "Therapeutic area or condition filter",
          "required": false
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results (default 20)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "trial_count": {
            "type": "integer"
          },
          "total_available": {
            "type": "integer"
          },
          "trials": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-safety-profile",
      "description": "Get AstraZeneca PLC aggregate safety profile from FAERS \u2014 top adverse reactions, outcomes, products with most reports",
      "parameters": [
        {
          "name": "product",
          "type": "string",
          "description": "Filter to specific product (brand or generic name)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "total_reports": {
            "type": "integer"
          },
          "top_reactions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "top_products_by_reports": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "outcome_distribution": {
            "type": "object"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-recalls",
      "description": "Get AstraZeneca PLC product recalls and enforcement actions from FDA",
      "parameters": [
        {
          "name": "classification",
          "type": "string",
          "description": "Filter: Class I, Class II, Class III",
          "required": false
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results (default 20)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "recall_count": {
            "type": "integer"
          },
          "recalls": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-labeling-changes",
      "description": "Get recent safety labeling changes for AstraZeneca PLC products",
      "parameters": [
        {
          "name": "since_year",
          "type": "integer",
          "description": "Filter changes since year (default: current year - 2)",
          "required": false
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results (default 20)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "since_year": {
            "type": "integer"
          },
          "change_count": {
            "type": "integer"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-products",
      "description": "Search AstraZeneca PLC products by keyword \u2014 drug name, condition, or therapeutic area",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search keyword",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results (default 10)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "result_count": {
            "type": "integer"
          },
          "products": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-head-to-head",
      "description": "Compare AstraZeneca PLC adverse event reporting vs a competitor using PRR from FAERS",
      "parameters": [
        {
          "name": "competitor",
          "type": "string",
          "description": "Competitor company key (e.g. novartis, pfizer, merck)",
          "required": true
        },
        {
          "name": "event",
          "type": "string",
          "description": "MedDRA preferred term to compare (e.g. nausea, hepatotoxicity)",
          "required": true
        },
        {
          "name": "drug_class",
          "type": "string",
          "description": "Filter to specific pharmacologic class (EPC)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "event": {
            "type": "string"
          },
          "drug_class_filter": {
            "type": "string"
          },
          "company_a": {
            "type": "object",
            "description": "This company: event_reports, total_reports, event_rate, prr_vs_competitor"
          },
          "company_b": {
            "type": "object",
            "description": "Competitor: event_reports, total_reports, event_rate, prr_vs_competitor"
          },
          "interpretation": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ]
}
