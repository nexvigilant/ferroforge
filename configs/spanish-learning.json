{
  "site": "learn.nexvigilant.com",
  "description": "Spanish language learning tools using pharmacovigilance primitive decomposition — cognate analysis, conjugation tiers, subjunctive mood gates",
  "tools": [
    {
      "name": "classify-cognate",
      "description": "Classify English-Spanish cognate confidence using Latin root analysis and suffix patterns (-tion, -al). Returns transfer strategy.",
      "parameters": [
        {"name": "latin_root", "type": "boolean", "required": true, "description": "Whether the word has a Latin/Romance root"},
        {"name": "ends_in_tion", "type": "boolean", "required": false, "description": "Word ends in -tion/-sion"},
        {"name": "ends_in_al", "type": "boolean", "required": false, "description": "Word ends in -al/-ial"},
        {"name": "syllable_count", "type": "integer", "required": false, "description": "Number of syllables"}
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "cognate_confidence": {"type": "string", "enum": ["high", "moderate", "low"]},
          "learning_strategy": {"type": "string", "enum": ["transfer", "pattern_match", "memorize"]}
        }
      },
      "annotations": {"readOnlyHint": true, "destructiveHint": false}
    },
    {
      "name": "classify-conjugation-tier",
      "description": "Classify Spanish verb conjugation difficulty tier (1-4). Tier 1: regular -ar (easiest, 80% of verbs). Tier 4: irregular reflexive (hardest).",
      "parameters": [
        {"name": "verb_ending", "type": "string", "required": true, "description": "Verb ending: ar, er, or ir"},
        {"name": "is_regular", "type": "boolean", "required": true, "description": "Whether the verb is regular"},
        {"name": "is_reflexive", "type": "boolean", "required": false, "description": "Whether the verb is reflexive"}
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "tier": {"type": "integer"},
          "practice_reps": {"type": "integer"},
          "example_verb": {"type": "string"}
        }
      },
      "annotations": {"readOnlyHint": true, "destructiveHint": false}
    },
    {
      "name": "check-subjunctive",
      "description": "Determine if Spanish subjunctive mood is needed using WEIRDO framework (Wishes, Emotions, Impersonal, Recommendations, Doubt, Ojala).",
      "parameters": [
        {"name": "is_factual", "type": "boolean", "required": true, "description": "Is the statement factual?"},
        {"name": "expresses_doubt", "type": "boolean", "required": false, "description": "Expresses doubt or uncertainty"},
        {"name": "expresses_desire", "type": "boolean", "required": false, "description": "Expresses wish or desire"},
        {"name": "expresses_emotion", "type": "boolean", "required": false, "description": "Expresses emotion"},
        {"name": "is_command", "type": "boolean", "required": false, "description": "Is a command or recommendation"}
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "mood": {"type": "string", "enum": ["subjunctive", "indicative"]},
          "reason": {"type": "string"},
          "mnemonic": {"type": "string"}
        }
      },
      "annotations": {"readOnlyHint": true, "destructiveHint": false}
    }
  ]
}
