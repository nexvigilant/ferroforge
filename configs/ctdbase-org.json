{
  "domain": "ctdbase.org",
  "url_pattern": "/*",
  "title": "Comparative Toxicogenomics Database",
  "description": "CTD \u2014 curated chemical-gene-disease interactions, toxicogenomic pathways, and exposure-outcome associations",
  "tools": [
    {
      "name": "search-chemical-gene",
      "description": "Search chemical-gene/protein interactions",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        },
        {
          "name": "gene",
          "type": "str",
          "description": "Gene",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-chemical-diseases",
