{
  "domain": "cccp.nexvigilant.com",
  "private": false,
  "copyright": "\u00a9 2026 NexVigilant, LLC.",
  "title": "CCCP \u2014 PV Competency Framework",
  "description": "Pharmacovigilance competency assessment tools: gap analysis across 15 PV domains, engagement planning with prioritized interventions, EPA readiness checking (21 EPAs), proficiency evaluation, and phase information. Based on the PDC framework with 1,286 KSBs and 623 behavioral anchors. Pure Rust via nexcore-cccp.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "gap-analysis",
      "description": "Compute gap analysis from current and desired proficiency levels across 15 PV domains. Returns domains with gaps, blocked EPAs, and overall readiness percentage. Levels: 1=Novice, 2=Advanced Beginner, 3=Competent, 4=Proficient, 5=Expert.",
      "parameters": [
        {
          "name": "current",
          "type": "array",
          "description": "Array of 15 current proficiency levels (integers 1-5)",
          "required": true
        },
        {
          "name": "desired",
          "type": "array",
          "description": "Array of 15 desired proficiency levels (integers 1-5)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "overall_readiness": {
            "type": "string"
          },
          "domains_with_gaps": {
            "type": "integer"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "plan",
      "description": "Generate an engagement plan with prioritized interventions to close proficiency gaps. Returns interventions with target domains, levels, priorities, and estimated sessions.",
      "parameters": [
        {
          "name": "current",
          "type": "array",
          "description": "Array of 15 current proficiency levels (integers 1-5)",
          "required": true
        },
        {
          "name": "desired",
          "type": "array",
          "description": "Array of 15 desired proficiency levels (integers 1-5)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "total_interventions": {
            "type": "integer"
          },
          "total_estimated_sessions": {
            "type": "integer"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "epa-readiness",
      "description": "Check readiness for all 21 Entrustable Professional Activities given current proficiency levels. Returns ready and blocked EPAs with blocking domains.",
      "parameters": [
        {
          "name": "current",
          "type": "array",
          "description": "Array of 15 current proficiency levels (integers 1-5)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "ready_count": {
            "type": "integer"
          },
          "blocked_count": {
            "type": "integer"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "evaluate",
      "description": "Evaluate how many of the 15 PV domains meet a target proficiency level. Returns domains at/above target and overall readiness verdict.",
      "parameters": [
        {
          "name": "current",
          "type": "array",
          "description": "Array of 15 current proficiency levels (integers 1-5)",
          "required": true
        },
        {
          "name": "target_level",
          "type": "integer",
          "description": "Target proficiency level (1-5, default: 3=Competent)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "verdict": {
            "type": "string"
          },
          "readiness_pct": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "phase-info",
      "description": "Get information about the 4 CCCP phases: Assessment, Planning, Development, Evaluation. Filter by phase name or get all.",
      "parameters": [
        {
          "name": "phase",
          "type": "string",
          "description": "Phase to query (e.g., 'assess', 'plan', 'develop', 'evaluate') or 'all'",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "framework": {
            "type": "string"
          },
          "domains": {
            "type": "integer"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "url_pattern": "/*"
}
