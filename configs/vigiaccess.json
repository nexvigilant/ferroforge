{
  "domain": "vigiaccess.org",
  "url_pattern": "/*",
  "title": "VigiAccess (WHO-UMC)",
  "description": "WHO global ICSR database \u2014 public access to worldwide adverse reaction reports from VigiBase",
  "proxy": "scripts/vigiaccess_proxy.py",
  "tools": [
    {
      "name": "search-reports",
      "description": "Search VigiBase reports by medicine name",
      "parameters": [
        {
          "name": "medicine",
          "type": "string",
          "description": "Medicine name (INN or brand)",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will search VigiAccess public interface for global ICSR counts by medicine.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      }
    },
    {
      "name": "get-adverse-reactions",
      "description": "Get adverse reaction breakdown by SOC for a medicine",
      "parameters": [
        {
          "name": "medicine",
          "type": "string",
          "description": "Medicine name",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will extract SOC-level reaction breakdown from VigiAccess results page.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-reporter-distribution",
      "description": "Get report distribution by reporter type (healthcare professional, consumer, etc.)",
      "parameters": [
        {
          "name": "medicine",
          "type": "string",
          "description": "Medicine name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
