{
  "domain": "chemivigilance.nexvigilant.com",
  "private": false,
  "copyright": "\u00a9 2026 NexVigilant, LLC.",
  "title": "Chemivigilance \u2014 Chemical Structure Safety Analysis",
  "description": "Chemical safety tools: SMILES parsing, molecular descriptors (Lipinski Ro5), Morgan fingerprints, Tanimoto/Dice similarity, ICH M7 structural alert scanning, QSAR toxicity prediction, metabolite prediction, safety briefs, substructure matching, and aromaticity analysis. Pure Rust via nexcore-chemivigilance, nexcore-molcore, nexcore-qsar, nexcore-structural-alerts.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "parse-smiles",
      "description": "Parse a SMILES string and return molecular graph info (atom count, bond count, connected components).",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string (e.g., 'CC(=O)Oc1ccccc1C(=O)O' for aspirin)", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "atom_count": { "type": "integer" }, "valid": { "type": "boolean" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "descriptors",
      "description": "Calculate Lipinski/physicochemical molecular descriptors: MW, LogP, TPSA, HBA, HBD, rotatable bonds, rings. Includes Rule of Five assessment.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "molecular_weight": { "type": "number" }, "lipinski_ro5": { "type": "object" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "fingerprint",
      "description": "Generate a Morgan/ECFP circular fingerprint with configurable radius and bit count.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true },
        { "name": "radius", "type": "integer", "description": "Fingerprint radius (default: 2)", "required": false },
        { "name": "nbits", "type": "integer", "description": "Number of bits (default: 2048)", "required": false }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "popcount": { "type": "integer" }, "density": { "type": "number" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "similarity",
      "description": "Compute Tanimoto and Dice similarity between two molecules using Morgan fingerprints.",
      "parameters": [
        { "name": "smiles_a", "type": "string", "description": "First SMILES", "required": true },
        { "name": "smiles_b", "type": "string", "description": "Second SMILES", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "tanimoto": { "type": "number" }, "dice": { "type": "number" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "structural-alerts",
      "description": "Scan a molecule for structural alerts (toxicophores) using the ICH M7 alert library. Returns matched alerts with categories and match counts.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "alert_count": { "type": "integer" }, "verdict": { "type": "string" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "predict-toxicity",
      "description": "Predict toxicity using QSAR models based on molecular structure and structural alert count.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "predictions": { "type": "object" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "predict-metabolites",
      "description": "Predict Phase I/II metabolites from molecular structure. Returns a metabolite tree.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "safety-brief",
      "description": "Generate a comprehensive safety brief for a molecule: descriptors, structural alerts, toxicity predictions, and metabolite analysis combined.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "substructure",
      "description": "Check if a query substructure exists in a target molecule. Returns match count.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "Target molecule SMILES", "required": true },
        { "name": "query", "type": "string", "description": "Query substructure SMILES", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "found": { "type": "boolean" }, "match_count": { "type": "integer" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "alert-library",
      "description": "List all structural alerts in the ICH M7 library with names, categories, and descriptions.",
      "parameters": [],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "alert_count": { "type": "integer" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "ring-scan",
      "description": "Find the Smallest Set of Smallest Rings (SSSR) in a molecule. Returns ring sizes and atom indices.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "ring_count": { "type": "integer" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "aromaticity",
      "description": "Detect aromatic rings and count \u03c0 electrons per ring using H\u00fcckel's rule.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "aromatic_ring_count": { "type": "integer" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "molecular-formula",
      "description": "Get molecular weight and heavy atom count from SMILES.",
      "parameters": [
        { "name": "smiles", "type": "string", "description": "SMILES string", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "molecular_weight": { "type": "number" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    }
  ]
}
