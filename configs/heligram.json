{
  "domain": "heligram.nexvigilant.com",
  "private": false,
  "copyright": "\u00a9 2026 NexVigilant, LLC.",
  "title": "Heligram \u2014 Helical Decision Programs",
  "description": "Dual-strand decision programs with built-in falsification. Each heligram runs a sense strand (assertion) and antisense strand (falsification) in parallel, resolving through a pairing matrix. Produces 4 verdicts where flat decision trees produce 2. Sub-microsecond execution via Rust.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "run",
      "description": "Run a heligram by name with input variables. Returns sense output, antisense output, agreement flag, and resolved verdict. Available heligrams: prr-signal-helix, ror-signal-helix.",
      "parameters": [
        {
          "name": "name",
          "type": "string",
          "description": "Heligram name (e.g. 'prr-signal-helix')",
          "required": true
        },
        {
          "name": "input",
          "type": "object",
          "description": "Input variables as key-value pairs",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "agreement": {
            "type": "boolean"
          },
          "sense": {
            "type": "object"
          },
          "antisense": {
            "type": "object"
          },
          "output": {
            "type": "object"
          },
          "duration_us": {
            "type": "integer"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "test",
      "description": "Run all self-tests for a heligram. Returns pass/fail counts and per-test details.",
      "parameters": [
        {
          "name": "name",
          "type": "string",
          "description": "Heligram name to test",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "total": {
            "type": "integer"
          },
          "passed": {
            "type": "integer"
          },
          "failed": {
            "type": "integer"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "list",
      "description": "List all available heligrams with their metadata: name, version, twist rate, base pair count, and test count.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "heligrams": {
            "type": "array"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "test-all",
      "description": "Run self-tests for all heligrams. Returns aggregate pass/fail and per-heligram breakdown.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "heligrams": {
            "type": "integer"
          },
          "total_tests": {
            "type": "integer"
          },
          "passed": {
            "type": "integer"
          },
          "failed": {
            "type": "integer"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "url_pattern": "/*"
}
