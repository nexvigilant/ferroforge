{
  "domain": "api.pharmgkb.org",
  "url_pattern": "/*",
  "title": "PharmGKB Pharmacogenomics",
  "description": "Pharmacogenomics knowledge \u2014 gene-drug-disease relationships, dosing guidelines, and variant annotations from PharmGKB",
  "tools": [
    {
      "name": "search-drugs",
      "description": "Search PharmGKB drug entries",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-drug-labels",
      "description": "Get FDA pharmacogenomic labeling for a drug",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-drug-genes",
      "description": "Get genes associated with drug response",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-clinical-annotations",
      "description": "Get clinical annotations for gene-drug pairs",
      "parameters": [
        {
          "name": "gene",
          "type": "string",
          "description": "Gene",
          "required": true
        },
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-dosing-guidelines",
      "description": "Get CPIC/DPWG dosing guidelines for a drug",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-variants",
      "description": "Search pharmacogenomic variants by rsID or gene",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-variant-annotations",
      "description": "Get clinical significance of a pharmacogenomic variant",
      "parameters": [
        {
          "name": "variant_id",
          "type": "string",
          "description": "Variant Id",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "scripts/api_pharmgkb_org_proxy.py"
}
