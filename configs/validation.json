{
  "domain": "validation.nexvigilant.com",
  "url_pattern": "/*",
  "title": "Validation Engine",
  "description": "Test classification, domain validation, and quality checks",
  "tools": [
    {
      "name": "validation-check",
      "description": "Quick check (L1-L2 only)",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "validation-classify-tests",
      "description": "Classify tests in a Rust source path",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "validation-domains",
      "description": "List available validation domains",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "validation-run",
      "description": "Run full L1-L5 validation",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
