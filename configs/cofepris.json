{
  "domain": "www.gob.mx/cofepris",
  "description": "COFEPRIS (Comisi\u00f3n Federal para la Protecci\u00f3n contra Riesgos Sanitarios) \u2014 Mexico's FDA equivalent. Drug approvals, safety alerts, pharmacovigilance reports, and regulatory actions for the Mexican market.",
  "tools": [
    {
      "name": "search-drug-registry",
      "description": "Buscar medicamentos en el Registro Sanitario de COFEPRIS por nombre, sustancia activa, o laboratorio. Search Mexico's drug registry by name, active substance, or manufacturer.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Nombre del medicamento o sustancia activa / Drug name or active substance",
          "required": true
        },
        {
          "name": "laboratorio",
          "type": "string",
          "description": "Nombre del laboratorio fabricante / Manufacturer name",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "registro_sanitario": {
                  "type": "string"
                },
                "denominacion_generica": {
                  "type": "string"
                },
                "denominacion_distintiva": {
                  "type": "string"
                },
                "laboratorio": {
                  "type": "string"
                },
                "forma_farmaceutica": {
                  "type": "string"
                },
                "clasificacion": {
                  "type": "string"
                }
              }
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-safety-alerts",
      "description": "Obtener alertas sanitarias y comunicados de riesgo emitidos por COFEPRIS. Get safety alerts and risk communications issued by Mexico's health authority.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Nombre del medicamento / Drug name",
          "required": false
        },
        {
          "name": "year",
          "type": "integer",
          "description": "A\u00f1o de la alerta / Alert year",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "alerts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fecha": {
                  "type": "string"
                },
                "titulo": {
                  "type": "string"
                },
                "tipo": {
                  "type": "string"
                },
                "sustancia_activa": {
                  "type": "string"
                },
                "accion_regulatoria": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-pharmacovigilance-reports",
      "description": "Obtener reportes de farmacovigilancia y reacciones adversas reportadas al CNFV (Centro Nacional de Farmacovigilancia). Get adverse reaction reports from Mexico's National Pharmacovigilance Center.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Nombre del medicamento / Drug name",
          "required": true
        },
        {
          "name": "reaction",
          "type": "string",
          "description": "Reacci\u00f3n adversa buscada / Adverse reaction query",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "drug": {
            "type": "string"
          },
          "total_reports": {
            "type": "integer"
          },
          "seriousness_distribution": {
            "type": "object",
            "properties": {
              "grave": {
                "type": "integer"
              },
              "no_grave": {
                "type": "integer"
              },
              "mortal": {
                "type": "integer"
              }
            }
          },
          "top_reactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reaction": {
                  "type": "string"
                },
                "count": {
                  "type": "integer"
                }
              }
            }
          },
          "source": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-recall-actions",
      "description": "Obtener retiros de medicamentos del mercado mexicano ordenados por COFEPRIS. Get drug recalls and market withdrawals ordered by Mexico's health authority.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Nombre del medicamento o laboratorio / Drug or manufacturer name",
          "required": false
        },
        {
          "name": "year",
          "type": "integer",
          "description": "A\u00f1o del retiro / Recall year",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "recalls": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fecha": {
                  "type": "string"
                },
                "medicamento": {
                  "type": "string"
                },
                "laboratorio": {
                  "type": "string"
                },
                "motivo": {
                  "type": "string"
                },
                "lote": {
                  "type": "string"
                },
                "tipo_retiro": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-regulatory-classification",
      "description": "Obtener la clasificaci\u00f3n regulatoria de un medicamento en M\u00e9xico (Fracci\u00f3n I-VI del Art\u00edculo 226 LGS). Get a drug's regulatory classification in Mexico \u2014 OTC, prescription, controlled substance categories.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "description": "Nombre del medicamento / Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "drug": {
            "type": "string"
          },
          "fraccion": {
            "type": "string"
          },
          "classification": {
            "type": "string"
          },
          "description_es": {
            "type": "string"
          },
          "description_en": {
            "type": "string"
          },
          "requires_prescription": {
            "type": "boolean"
          },
          "controlled": {
            "type": "boolean"
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "url_pattern": "/*",
  "title": "cofepris",
  "proxy": "rust-native"
}
