{
  "domain": "antivector.nexvigilant.com",
  "private": false,
  "copyright": "© 2026 NexVigilant, LLC. Anti-vector computation — structured countermeasures that annihilate harm vectors — is a proprietary NexVigilant method.",
  "title": "Anti-Vector — Harm Countermeasure Computation",
  "description": "Compute structured countermeasures (anti-vectors) for pharmacovigilance signals. Three anti-vector classes: Mechanistic (breaks causal pathway), Epistemic (counters false signals with structured evidence), Architectural (engineers proportionate risk minimization). Maps all 8 harm types (A-H) to their anti-vector strategies. Pure Rust via nexcore-antivector.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "antivector_classify",
      "description": "Classify a harm type (A-I) into its anti-vector strategy. Returns primary class (mechanistic/epistemic/architectural), recommended measures, and common biases.",
      "parameters": [
        {
          "name": "harm_type",
          "type": "string",
          "required": true,
          "description": "Harm type letter: A (Acute), B (Cumulative), C (Off-Target), D (Cascade), E (Idiosyncratic), F (Saturation), G (Interaction), H (Population), I (Goal Misalignment)"
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "harm_type": { "type": "string" },
          "primary_class": { "type": "string" },
          "secondary_class": { "type": "string" },
          "description": { "type": "string" },
          "measures": { "type": "array", "items": { "type": "string" } },
          "common_biases": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["harm_type", "primary_class", "description", "measures"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "antivector_compute",
      "description": "Compute a complete anti-vector for a drug-event harm vector. Returns mechanistic, epistemic, and architectural components with annihilation result (residual harm / annihilated / surplus protection).",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "required": true,
          "description": "Drug or intervention name"
        },
        {
          "name": "event",
          "type": "string",
          "required": true,
          "description": "Adverse event or harm outcome"
        },
        {
          "name": "harm_type",
          "type": "string",
          "required": true,
          "description": "Harm type letter: A-I"
        },
        {
          "name": "magnitude",
          "type": "number",
          "required": true,
          "description": "Signal magnitude (0.0 to 1.0)"
        },
        {
          "name": "confidence",
          "type": "number",
          "required": false,
          "description": "Confidence in the signal (0.0 to 1.0, default 0.5)"
        },
        {
          "name": "pathway",
          "type": "string",
          "required": false,
          "description": "Causal pathway description"
        },
        {
          "name": "bias_type",
          "type": "string",
          "required": false,
          "description": "Bias to assess: indication, notoriety, weber, channeling, protopathic, depletion, stimulated, duplicate"
        },
        {
          "name": "bias_magnitude",
          "type": "number",
          "required": false,
          "description": "Bias magnitude (0.0 to 1.0)"
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "harm_vector": { "type": "object" },
          "anti_vector_magnitude": { "type": "number" },
          "has_mechanistic": { "type": "boolean" },
          "has_epistemic": { "type": "boolean" },
          "has_architectural": { "type": "boolean" },
          "epistemic_verdict": { "type": "string" },
          "architectural_measure": { "type": "string" },
          "annihilation_result": { "type": "object" }
        },
        "required": ["harm_vector", "anti_vector_magnitude", "annihilation_result"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "antivector_report",
      "description": "Generate a human-readable annihilation report for a drug-event pair. Shows all anti-vector components and final outcome.",
      "parameters": [
        {
          "name": "drug",
          "type": "string",
          "required": true,
          "description": "Drug or intervention name"
        },
        {
          "name": "event",
          "type": "string",
          "required": true,
          "description": "Adverse event or harm outcome"
        },
        {
          "name": "harm_type",
          "type": "string",
          "required": true,
          "description": "Harm type letter: A-I"
        },
        {
          "name": "magnitude",
          "type": "number",
          "required": true,
          "description": "Signal magnitude (0.0 to 1.0)"
        },
        {
          "name": "confidence",
          "type": "number",
          "required": false,
          "description": "Confidence in signal (0.0 to 1.0, default 0.5)"
        },
        {
          "name": "pathway",
          "type": "string",
          "required": false,
          "description": "Causal pathway description"
        },
        {
          "name": "bias_type",
          "type": "string",
          "required": false,
          "description": "Bias to assess"
        },
        {
          "name": "bias_magnitude",
          "type": "number",
          "required": false,
          "description": "Bias magnitude (0.0 to 1.0)"
        },
        {
          "name": "intervention",
          "type": "string",
          "required": false,
          "description": "Mechanistic intervention description"
        },
        {
          "name": "expected_attenuation",
          "type": "number",
          "required": false,
          "description": "Expected attenuation from intervention (0.0 to 1.0)"
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "drug": { "type": "string" },
          "event": { "type": "string" },
          "harm_type": { "type": "string" },
          "harm_magnitude": { "type": "number" },
          "anti_vector_magnitude": { "type": "number" },
          "mechanistic": { "type": "string" },
          "epistemic": { "type": "string" },
          "architectural": { "type": "string" },
          "outcome": { "type": "string" }
        },
        "required": ["drug", "event", "outcome"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ]
}
