{
  "domain": "helix.nexvigilant.com",
  "private": false,
  "copyright": "\u00a9 2026 NexVigilant, LLC. Helix Computing by Matthew A. Campion, PharmD. NexVigilant Source Available License v1.0.",
  "title": "Helix Computing \u2014 Conservation Law as Computable Geometry",
  "description": "The conservation law \u2203 = \u2202(\u00d7(\u03c2, \u2205)) encodes a helix: it advances (\u2192), returns (\u03ba), and bounds (\u2202). Five tools make this geometry computable: conservation checks, helix position, mutualism validation, concept encoding through 5 turns (Primitives\u2192Conservation\u2192Laws\u2192Calculus\u2192Mutualism), and turn advancement. Pure Rust \u2014 no network calls.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "conservation-check",
      "description": "Validate \u2203 = \u2202(\u00d7(\u03c2, \u2205)) for a system. Inputs: boundary sharpness \u2202 \u2208 [0,1], state richness \u03c2 \u2208 [0,1], void clarity \u2205 \u2208 [0,1]. Returns existence score \u2203, classification, and which primitive is weakest.",
      "parameters": [
        {
          "name": "boundary",
          "type": "number",
          "description": "\u2202 \u2014 boundary sharpness [0,1]. How sharply defined is inside vs outside?",
          "required": true
        },
        {
          "name": "state",
          "type": "number",
          "description": "\u03c2 \u2014 state richness [0,1]. How much observable state exists within the boundary?",
          "required": true
        },
        {
          "name": "void",
          "type": "number",
          "description": "\u2205 \u2014 void clarity [0,1]. How clearly defined is what the system is NOT?",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "existence": {
            "type": "number"
          },
          "boundary": {
            "type": "number"
          },
          "state": {
            "type": "number"
          },
          "void": {
            "type": "number"
          },
          "weakest_primitive": {
            "type": "string"
          },
          "classification": {
            "type": "string"
          },
          "formula": {
            "type": "string"
          },
          "interpretation": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "helix-position",
      "description": "Compute position on the knowledge helix. Five turns: 0=Primitives (alphabet), 1=Conservation (grammar), 2=Crystalbook (laws), 3=Derivative Identity (calculus), 4=Mutualism (the point). Each turn has the same angular truth at higher resolution. Returns turn metadata, altitude, and what encoding layer you occupy.",
      "parameters": [
        {
          "name": "turn",
          "type": "integer",
          "description": "Helix turn number (0-4). 0=Primitives, 1=Conservation, 2=Crystalbook, 3=Derivative Identity, 4=Mutualism.",
          "required": true
        },
        {
          "name": "theta",
          "type": "number",
          "description": "Angular position within the turn [0, 2\u03c0]. Default: 0 (entry point).",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "turn": {
            "type": "integer"
          },
          "turn_name": {
            "type": "string"
          },
          "what": {
            "type": "string"
          },
          "encoding": {
            "type": "string"
          },
          "altitude": {
            "type": "number"
          },
          "theta": {
            "type": "number"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "z": {
            "type": "number"
          },
          "helix_properties": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "mutualism-test",
      "description": "Test whether an action satisfies the mutualism constraint: does it produce \u2203 for self WITHOUT reducing \u2203 for others? Conservation says \u2203_self and \u2203_other share the same constraint. Producing yours by destroying theirs violates conservation.",
      "parameters": [
        {
          "name": "existence_self_before",
          "type": "number",
          "description": "\u2203 of self before the action [0,1]",
          "required": true
        },
        {
          "name": "existence_self_after",
          "type": "number",
          "description": "\u2203 of self after the action [0,1]",
          "required": true
        },
        {
          "name": "existence_other_before",
          "type": "number",
          "description": "\u2203 of other(s) before the action [0,1]",
          "required": true
        },
        {
          "name": "existence_other_after",
          "type": "number",
          "description": "\u2203 of other(s) after the action [0,1]",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "mutualistic": {
            "type": "boolean"
          },
          "delta_self": {
            "type": "number"
          },
          "delta_other": {
            "type": "number"
          },
          "net_existence": {
            "type": "number"
          },
          "classification": {
            "type": "string"
          },
          "conservation_holds": {
            "type": "boolean"
          },
          "interpretation": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "encode",
      "description": "Encode a concept through all 5 helix turns. Given a concept name and its primitives, returns the encoding at each altitude: what symbols compose it (turn 0), how conservation constrains it (turn 1), which laws govern it (turn 2), how it changes (turn 3), and whether it serves mutualism (turn 4).",
      "parameters": [
        {
          "name": "concept",
          "type": "string",
          "description": "The concept to encode (e.g., 'signal detection', 'drug safety', 'team coordination')",
          "required": true
        },
        {
          "name": "primitives",
          "type": "array",
          "description": "T1 primitives composing this concept (e.g., ['\u03bd', '\u2202', '\u03c2', '\u03ba'])",
          "required": true
        },
        {
          "name": "boundary",
          "type": "number",
          "description": "\u2202 score for this concept [0,1]",
          "required": true
        },
        {
          "name": "state",
          "type": "number",
          "description": "\u03c2 score for this concept [0,1]",
          "required": true
        },
        {
          "name": "void",
          "type": "number",
          "description": "\u2205 score for this concept [0,1]",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "concept": {
            "type": "string"
          },
          "turns": {
            "type": "array"
          },
          "existence": {
            "type": "number"
          },
          "helix_complete": {
            "type": "boolean"
          },
          "mutualism_score": {
            "type": "number"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "advance",
      "description": "Advance one turn on the helix. Given current turn and state, compute what the next turn requires. The truth doesn't change between turns \u2014 the resolution does. Returns the gap between current and next altitude.",
      "parameters": [
        {
          "name": "current_turn",
          "type": "integer",
          "description": "Current helix turn (0-3). Cannot advance past turn 4.",
          "required": true
        },
        {
          "name": "current_existence",
          "type": "number",
          "description": "Current \u2203 score [0,1]",
          "required": true
        },
        {
          "name": "current_boundary",
          "type": "number",
          "description": "Current \u2202 score [0,1]",
          "required": true
        },
        {
          "name": "current_state",
          "type": "number",
          "description": "Current \u03c2 score [0,1]",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "from_turn": {
            "type": "integer"
          },
          "to_turn": {
            "type": "integer"
          },
          "from_name": {
            "type": "string"
          },
          "to_name": {
            "type": "string"
          },
          "altitude_gap": {
            "type": "number"
          },
          "requirement": {
            "type": "string"
          },
          "readiness": {
            "type": "number"
          },
          "can_advance": {
            "type": "boolean"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "url_pattern": "/*"
}
