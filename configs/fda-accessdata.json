{
  "domain": "accessdata.fda.gov",
  "url_pattern": "/*",
  "title": "FDA AccessData",
  "description": "FDA drug approvals, Orange Book, REMS, and recall data",
  "proxy": "scripts/accessdata_proxy.py",
  "tools": [
    {
      "name": "search-approvals",
      "description": "Search FDA drug approval history by drug name or application number",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name or active ingredient",
          "required": true
        },
        {
          "name": "application_type",
          "type": "string",
          "description": "NDA, ANDA, or BLA",
          "required": false
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will query Drugs@FDA database for approval records.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      }
    },
    {
      "name": "get-approval-history",
      "description": "Get full approval timeline for a drug including supplements",
      "parameters": [
        {
          "name": "application_number",
          "type": "string",
          "description": "NDA/BLA number",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-labeling-changes",
      "description": "Get safety-related labeling changes (CBE supplements) for a drug",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-orange-book",
      "description": "Get Orange Book patent and exclusivity data",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-rems",
      "description": "Get Risk Evaluation and Mitigation Strategy details",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "search-recalls",
      "description": "Search drug recalls and safety alerts",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Drug name or recall reason",
          "required": true
        },
        {
          "name": "classification",
          "type": "string",
          "description": "Class I, II, or III",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      }
    }
  ]
}
