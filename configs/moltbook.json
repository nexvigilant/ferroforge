{
  "domain": "moltbook.nexvigilant.com",
  "url_pattern": "/*",
  "title": "MoltBook \u2014 Config Discovery & Contribution",
  "description": "Discover, contribute, and monitor NexVigilant Station configs via MCP. The agent-facing API for the Molt ecosystem: find tools by domain, submit new configs, check health, and generate proxy scripts.",
  "tools": [
    {
      "name": "lookup",
      "description": "Find configs and tools for a specific domain. Returns matching configs with tool names, descriptions, and source types. Example: lookup({\"domain\": \"dailymed\"}) returns DailyMed config with 6 tools.",
      "parameters": [
        {
          "name": "domain",
          "type": "string",
          "description": "Domain to search (partial match, e.g., 'fda', 'dailymed', 'eudravigilance')",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "configs": {
            "type": "array"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "catalog",
      "description": "List ALL configs in the Station with summary stats \u2014 total tools, source type breakdown (rust-native vs live-api vs reference), and per-config tool counts. The full inventory.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "totalConfigs": {
            "type": "integer"
          },
          "totalTools": {
            "type": "integer"
          },
          "bySourceType": {
            "type": "object"
          },
          "configs": {
            "type": "array"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "contribute",
      "description": "Submit a new config to the Station. Provide domain, title, and tools array. Each tool needs name + description. Config is persisted and available after restart.",
      "parameters": [
        {
          "name": "domain",
          "type": "string",
          "description": "Domain for the new config (e.g., 'newsite.example.com')",
          "required": true
        },
        {
          "name": "title",
          "type": "string",
          "description": "Human-readable title for the config",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "description": "What this config provides",
          "required": false
        },
        {
          "name": "tools",
          "type": "array",
          "description": "Array of tool objects, each with 'name' and 'description'",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "toolCount": {
            "type": "integer"
          },
          "configPath": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false
      }
    },
    {
      "name": "watch",
      "description": "Check health of all configs \u2014 healthy vs degraded vs stub-only. Returns summary stats and lists degraded configs that need attention.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "summary": {
            "type": "object"
          },
          "degraded": {
            "type": "array"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "generate",
      "description": "Get instructions for generating a proxy script from a config. Explains the MoltProxy pipeline: config JSON \u2192 generated Python script \u2192 dispatch wiring \u2192 deploy.",
      "parameters": [
        {
          "name": "domain",
          "type": "string",
          "description": "Domain to generate proxy for",
          "required": false
        },
        {
          "name": "mode",
          "type": "string",
          "description": "Generation mode: 'api' (urllib) or 'browser' (Playwright)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "instructions": {
            "type": "object"
          },
          "modes": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "rust-native"
}
