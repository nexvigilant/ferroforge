{
  "domain": "clinicaltrials.gov",
  "url_pattern": "/*",
  "title": "ClinicalTrials.gov Registry",
  "description": "Search and extract clinical trial data including safety endpoints, SAEs, and study design",
  "proxy": "scripts/clinicaltrials_proxy.py",
  "tools": [
    {
      "name": "search-trials",
      "description": "Search clinical trials by drug, condition, sponsor, or status. The 'query' parameter is always required as the primary search term (e.g. drug name). Use condition, intervention, status, and phase as optional filters to narrow results.",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Required free-text search term (e.g. 'semaglutide', 'breast cancer checkpoint inhibitor'). This is the primary search — condition/intervention/status are optional filters applied on top.",
          "required": true
        },
        {
          "name": "condition",
          "type": "string",
          "description": "Medical condition or disease",
          "required": false
        },
        {
          "name": "intervention",
          "type": "string",
          "description": "Drug or intervention name",
          "required": false
        },
        {
          "name": "status",
          "type": "string",
          "description": "Trial status (RECRUITING, COMPLETED, TERMINATED)",
          "required": false
        },
        {
          "name": "phase",
          "type": "string",
          "description": "Trial phase (1, 2, 3, 4)",
          "required": false
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum results to return (default 10, max 100)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "total_count": {
            "type": "integer"
          },
          "returned": {
            "type": "integer"
          },
          "trials": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "nct_id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "phase": {
                  "type": "string"
                },
                "conditions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "interventions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "required": [
          "status",
          "trials"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-trial",
      "description": "Get full trial record by NCT ID",
      "parameters": [
        {
          "name": "nct_id",
          "type": "string",
          "description": "NCT identifier (e.g., NCT04280705)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "nct_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "overall_status": {
            "type": "string",
            "description": "Trial status (RECRUITING, COMPLETED, etc.)"
          },
          "phase": {
            "type": "string"
          },
          "enrollment": {
            "type": "object"
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "interventions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-safety-endpoints",
      "description": "Extract safety and adverse event endpoints from a trial's outcomes module",
      "parameters": [
        {
          "name": "nct_id",
          "type": "string",
          "description": "NCT identifier",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "nct_id": {
            "type": "string",
            "description": "ClinicalTrials.gov identifier"
          },
          "title": {
            "type": "string",
            "description": "Study title"
          },
          "safety_primary_endpoints": {
            "type": "array",
            "description": "Primary outcomes with safety relevance"
          },
          "safety_secondary_endpoints": {
            "type": "array",
            "description": "Secondary outcomes with safety relevance"
          },
          "safety_other_endpoints": {
            "type": "array",
            "description": "Other outcomes with safety relevance"
          },
          "safety_endpoint_count": {
            "type": "integer",
            "description": "Total safety-relevant endpoints"
          },
          "total_primary_outcomes": {
            "type": "integer",
            "description": "Total primary outcomes"
          },
          "total_secondary_outcomes": {
            "type": "integer",
            "description": "Total secondary outcomes"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-serious-adverse-events",
      "description": "Get reported serious adverse events from trial results (requires posted results). Use filter_event to narrow large result sets to specific events or organ systems.",
      "parameters": [
        {
          "name": "nct_id",
          "type": "string",
          "description": "NCT identifier",
          "required": true
        },
        {
          "name": "filter_event",
          "type": "string",
          "description": "Optional case-insensitive filter — only return SAEs whose term or organ system contains this substring (e.g. 'pancreatitis', 'cardiac', 'neoplasm'). Omit to return all SAEs.",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "nct_id": {
            "type": "string",
            "description": "ClinicalTrials.gov identifier"
          },
          "title": {
            "type": "string",
            "description": "Study title"
          },
          "has_results": {
            "type": "boolean",
            "description": "Whether trial has posted results"
          },
          "serious_adverse_events": {
            "type": "array",
            "description": "SAE terms with counts per group"
          },
          "group_summary": {
            "type": "array",
            "description": "Participant groups with affected/at-risk counts"
          },
          "total_sae_terms": {
            "type": "integer",
            "description": "Total SAE terms reported"
          },
          "frequency_threshold": {
            "type": "string",
            "description": "Reporting frequency threshold"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-results-summary",
      "description": "Get a high-level results summary for a completed trial: participant flow, baseline demographics, primary/secondary outcome measures, and adverse event overview. Requires posted results.",
      "parameters": [
        {
          "name": "nct_id",
          "type": "string",
          "description": "NCT identifier (e.g., NCT03548935)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "nct_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "has_results": {
            "type": "boolean",
            "description": "Whether trial has posted results"
          },
          "participant_flow": {
            "type": "object",
            "description": "Groups and period milestones with participant counts"
          },
          "baseline_population": {
            "type": "string",
            "description": "Baseline population description"
          },
          "outcome_measures": {
            "type": "array",
            "description": "Primary and secondary outcome measures with results (top 10)"
          },
          "adverse_events_overview": {
            "type": "object",
            "description": "High-level AE summary: group counts for serious, other, and death events"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "compare-trial-arms",
      "description": "Compare adverse event rates between treatment and control arms (requires posted results)",
      "parameters": [
        {
          "name": "nct_id",
          "type": "string",
          "description": "NCT identifier",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "nct_id": {
            "type": "string"
          },
          "arms": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-eligibility-criteria",
      "description": "Extract eligibility criteria (inclusion/exclusion), age range, sex, and healthy volunteer status from a trial",
      "parameters": [
        {
          "name": "nct_id",
          "type": "string",
          "description": "NCT identifier (e.g., NCT04280705)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "nct_id": {
            "type": "string"
          },
          "criteria": {
            "type": "object",
            "properties": {
              "sex": {
                "type": "string"
              },
              "minimum_age": {
                "type": "string"
              },
              "maximum_age": {
                "type": "string"
              },
              "healthy_volunteers": {
                "type": "boolean"
              },
              "inclusion_criteria": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "exclusion_criteria": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-study-design",
      "description": "Extract study design details \u2014 randomization, blinding, masking, allocation, phases, enrollment, and arm count",
      "parameters": [
        {
          "name": "nct_id",
          "type": "string",
          "description": "NCT identifier (e.g., NCT04280705)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "nct_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "design": {
            "type": "object",
            "properties": {
              "study_type": {
                "type": "string"
              },
              "phases": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "allocation": {
                "type": "string"
              },
              "intervention_model": {
                "type": "string"
              },
              "primary_purpose": {
                "type": "string"
              },
              "masking": {
                "type": "object"
              },
              "enrollment": {
                "type": "object"
              },
              "number_of_arms": {
                "type": "string"
              }
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ]
}
