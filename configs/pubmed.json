{
  "domain": "pubmed.ncbi.nlm.nih.gov",
  "url_pattern": "/*",
  "title": "PubMed Literature",
  "description": "Biomedical literature search \u2014 case reports, signal papers, and PV research",
  "tools": [
    {
      "name": "search-articles",
      "description": "Search PubMed for articles by keyword, MeSH term, or author",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query (supports PubMed syntax)",
          "required": true
        },
        {
          "name": "mesh_terms",
          "type": "string",
          "description": "MeSH terms to include",
          "required": false
        },
        {
          "name": "date_range",
          "type": "string",
          "description": "Date range (e.g., '2020:2024')",
          "required": false
        },
        {
          "name": "article_type",
          "type": "string",
          "description": "Article type filter (case report, meta-analysis, review)",
          "required": false
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum results (default 10, max 50)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "total_found": {
            "type": "integer"
          },
          "returned": {
            "type": "integer"
          },
          "articles": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "pmid": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "authors": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "journal": {
                  "type": "string"
                },
                "year": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "status",
          "articles"
        ]
      }
    },
    {
      "name": "get-abstract",
      "description": "Get article abstract, metadata, and MeSH headings by PMID",
      "parameters": [
        {
          "name": "pmid",
          "type": "string",
          "description": "PubMed ID",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "pmid": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "abstract": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-citations",
      "description": "Get articles that cite a given PMID (via elink citedin; limited to PMC-indexed articles)",
      "parameters": [
        {
          "name": "pmid",
          "type": "string",
          "description": "PubMed ID to find citations for",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "pmid": {
            "type": "string"
          },
          "citations": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "search-case-reports",
      "description": "Search specifically for adverse event case reports for a drug",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        },
        {
          "name": "adverse_event",
          "type": "string",
          "description": "Adverse event term (optional, narrows results)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "total_found": {
            "type": "integer"
          },
          "articles": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "search-signal-literature",
      "description": "Find pharmacovigilance signal detection papers for a drug (PRR, ROR, disproportionality, spontaneous reports)",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "total_found": {
            "type": "integer"
          },
          "articles": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-mesh-terms",
      "description": "Extract MeSH headings assigned to an article — descriptors, qualifiers, major topic flags, and chemical substances. Useful for MedDRA concept mapping.",
      "parameters": [
        {
          "name": "pmid",
          "type": "string",
          "description": "PubMed ID",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "pmid": {
            "type": "string"
          },
          "mesh_heading_count": {
            "type": "integer"
          },
          "mesh_headings": {
            "type": "array",
            "items": { "type": "object" }
          },
          "chemicals": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["status"]
      }
    },
    {
      "name": "get-related-articles",
      "description": "Find articles related to a given PMID using PubMed's similarity algorithm. Returns top related articles with metadata.",
      "parameters": [
        {
          "name": "pmid",
          "type": "string",
          "description": "PubMed ID",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum results (default 10, max 50)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "pmid": {
            "type": "string"
          },
          "related_count": {
            "type": "integer"
          },
          "related_articles": {
            "type": "array",
            "items": { "type": "object" }
          }
        },
        "required": ["status"]
      }
    }
  ],
  "proxy": "scripts/pubmed_proxy.py"
}
