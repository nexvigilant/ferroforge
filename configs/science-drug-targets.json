{
  "domain": "science.nexvigilant.com",
  "copyright": "\u00a9 2026 NexVigilant, LLC. Drug target curation and safety assessment methodology are proprietary.",
  "url_pattern": "/targets/*",
  "title": "Drug Target Intelligence",
  "description": "AI-powered drug target analysis \u2014 ChEMBL bioactivity, UniProt profiles, PDB structures, clinical candidate pipelines, and target safety assessment. Built by NexVigilant (https://nexvigilant.com).",
  "tools": [
    {
      "name": "search-targets",
      "description": "Search ChEMBL for drug targets by gene name, protein name, or disease",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Gene name, protein name, or disease keyword",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "targets"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-target-profile",
      "description": "Get comprehensive target profile from UniProt \u2014 protein function, structure, subcellular location, and disease associations",
      "parameters": [
        {
          "name": "uniprot_id",
          "type": "string",
          "description": "UniProt accession (e.g., P04637 for TP53)",
          "required": false
        },
        {
          "name": "gene",
          "type": "string",
          "description": "Gene name (e.g., EGFR, BRAF)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "accession": {
            "type": "string"
          },
          "protein_name": {
            "type": "string"
          },
          "gene_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "function": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-crystal-structures",
      "description": "Search PDB/RCSB for crystal structures of a target \u2014 resolution, method, and ligand co-crystals",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Target name or PDB query",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "structures": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-clinical-candidates",
      "description": "Get clinical candidate compounds targeting a specific protein from ChEMBL bioactivity data",
      "parameters": [
        {
          "name": "target_chembl_id",
          "type": "string",
          "description": "ChEMBL target ID (e.g., CHEMBL203 for EGFR)",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Max results (default 10)",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "activities": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-target-safety",
      "description": "Get published safety liabilities of modulating a target \u2014 knockout phenotypes, toxicity reports, and risk factors",
      "parameters": [
        {
          "name": "gene",
          "type": "string",
          "description": "Gene/target name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "articles": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "compute-target-score",
      "description": "Assess drug target druggability using multi-factor scoring \u2014 protein family, structural data, clinical precedent, genetic validation",
      "parameters": [
        {
          "name": "gene",
          "type": "string",
          "description": "Gene/target name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "factors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "scripts/science_proxy.py"
}
