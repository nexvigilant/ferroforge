{
  "domain": "game-theory.nexvigilant.com",
  "private": false,
  "copyright": "© 2026 NexVigilant, LLC.",
  "title": "Game Theory — Nash Equilibria & Payoff Analysis",
  "description": "Compute Nash equilibria for 2x2 games (pure + mixed strategies), analyze N×M payoff matrices (best responses, dominance, minimax), and solve general games. Pure Rust computation.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "nash-2x2",
      "description": "Find pure and mixed Nash equilibria for a 2x2 game. Provide row and column payoff matrices.",
      "parameters": [
        { "name": "row_payoffs", "type": "array", "description": "2x2 row player payoffs [[a,b],[c,d]]", "required": true },
        { "name": "col_payoffs", "type": "array", "description": "2x2 column player payoffs [[e,f],[g,h]]", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "pure_equilibria": { "type": "array" }, "mixed_equilibrium": { "type": "object" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "payoff-matrix",
      "description": "Analyze an N×M payoff matrix: best responses per row/column, dominance analysis, and minimax value.",
      "parameters": [
        { "name": "values", "type": "array", "description": "Flat array of payoff values (row-major)", "required": true },
        { "name": "rows", "type": "integer", "description": "Number of rows", "required": true },
        { "name": "cols", "type": "integer", "description": "Number of columns", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "matrix": { "type": "array" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "nash-solve",
      "description": "Solve a general N×M game for Nash equilibria using iterative elimination and minimax.",
      "parameters": [
        { "name": "row_values", "type": "array", "description": "Flat row payoffs (row-major)", "required": true },
        { "name": "col_values", "type": "array", "description": "Flat column payoffs (row-major)", "required": true },
        { "name": "rows", "type": "integer", "required": true },
        { "name": "cols", "type": "integer", "required": true }
      ],
      "outputSchema": { "type": "object", "properties": { "status": { "type": "string" }, "equilibria": { "type": "array" } }, "required": ["status"] },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    }
  ]
}
