{
  "domain": "regulatory-mesh.nexvigilant.com",
  "url_pattern": "/*",
  "title": "Regulatory Agency Cross-Reference Mesh",
  "description": "Lateral linkages between regulatory agencies. Maps equivalent actions, terminology, and classification systems across jurisdictions.",
  "tools": [
    {
      "name": "map-equivalent-actions",
      "description": "Map a regulatory action type to equivalent actions in other agencies. E.g., FDA 'boxed warning' = EMA 'contraindication' = PMDA 'red frame warning' = TGA 'black box'.",
      "parameters": [
        {
          "name": "action_type",
          "type": "str",
          "description": "Action Type",
          "required": true
        },
        {
          "name": "source_agency",
          "type": "str",
          "description": "Source Agency",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "translate-terminology",
      "description": "Translate PV terminology between agency frameworks. E.g., CIOMS seriousness criteria across FDA/EMA/PMDA interpretations.",
      "parameters": [
        {
          "name": "term",
          "type": "str",
          "description": "Term",
          "required": true
        },
        {
          "name": "from_agency",
          "type": "str",
          "description": "From Agency",
          "required": true
        },
        {
          "name": "to_agency",
          "type": "str",
          "description": "To Agency",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-reporting-requirements",
      "description": "Compare expedited reporting timelines across agencies \u2014 15-day (FDA), 15-day (EMA), 15-day (PMDA) for fatal/life-threatening, vs 90-day periodic.",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        },
        {
          "name": "event_type",
          "type": "str",
          "description": "Event Type",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
