      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "compare-classification-systems",
      "description": "Compare how agencies classify the same concept \u2014 seriousness criteria, causality assessment methods, expectedness definitions.",
      "parameters": [
        {
          "name": "system",
          "type": "str",
          "description": "System",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-mutual-recognition",
