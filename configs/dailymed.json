{
  "domain": "dailymed.nlm.nih.gov",
  "url_pattern": "/dailymed/*",
  "title": "DailyMed Drug Labels",
  "description": "Extract structured drug labeling data from DailyMed SPL documents",
  "tools": [
    {
      "name": "get-drug-label",
      "description": "Get full drug label (SPL) by drug name",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name to search for",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "drug_name": {
            "type": "string"
          },
          "brand_name": {
            "type": "string"
          },
          "generic_name": {
            "type": "string"
          },
          "setid": {
            "type": "string"
          },
          "boxed_warning": {
            "type": "string"
          },
          "adverse_reactions": {
            "type": "string"
          },
          "warnings_and_cautions": {
            "type": "string"
          },
          "drug_interactions": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-adverse-reactions",
      "description": "Extract adverse reactions section from a drug label",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "drug_name": {
            "type": "string"
          },
          "brand_name": {
            "type": "string"
          },
          "adverse_reactions": {
            "type": "string"
          },
          "boxed_warning": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "search-drugs",
      "description": "Search DailyMed for drugs by name, ingredient, or labeler",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum results to return",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "total_found": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "setid": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "labeler": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      }
    }
  ],
  "proxy": "scripts/dailymed_proxy.py"
}
