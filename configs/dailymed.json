{
  "domain": "dailymed.nlm.nih.gov",
  "url_pattern": "/dailymed/*",
  "title": "DailyMed Drug Labels",
  "description": "Extract structured drug labeling data from DailyMed SPL documents",
  "tools": [
    {
      "name": "get-drug-label",
      "description": "Get full drug label (SPL) by drug name",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name to search for",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "drug_name": {
            "type": "string"
          },
          "brand_name": {
            "type": "string"
          },
          "generic_name": {
            "type": "string"
          },
          "setid": {
            "type": "string"
          },
          "boxed_warning": {
            "type": "string"
          },
          "adverse_reactions": {
            "type": "string"
          },
          "warnings_and_cautions": {
            "type": "string"
          },
          "drug_interactions": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-adverse-reactions",
      "description": "Extract adverse reactions section from a drug label",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "drug_name": {
            "type": "string"
          },
          "brand_name": {
            "type": "string"
          },
          "adverse_reactions": {
            "type": "string"
          },
          "boxed_warning": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-drugs",
      "description": "Search DailyMed for drugs by name, ingredient, or labeler",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum results to return",
          "required": false
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "count": {
            "type": "integer",
            "description": "Results returned"
          },
          "total_matching": {
            "type": "integer",
            "description": "Total matching results"
          },
          "results": {
            "type": "array",
            "description": "Drug label results with title, setid, labeler"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-drug-interactions",
      "description": "Extract drug interactions section from a drug label \u2014 known drug-drug interactions and management",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | not_found"
          },
          "drug_name": {
            "type": "string"
          },
          "brand_name": {
            "type": "string"
          },
          "generic_name": {
            "type": "string"
          },
          "drug_interactions": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-contraindications",
      "description": "Extract contraindications section \u2014 conditions where the drug should NOT be used",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | not_found"
          },
          "drug_name": {
            "type": "string"
          },
          "brand_name": {
            "type": "string"
          },
          "generic_name": {
            "type": "string"
          },
          "contraindications": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-boxed-warning",
      "description": "Extract FDA Black Box Warning \u2014 the most serious safety warning on a drug label",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | not_found"
          },
          "drug_name": {
            "type": "string"
          },
          "brand_name": {
            "type": "string"
          },
          "generic_name": {
            "type": "string"
          },
          "has_boxed_warning": {
            "type": "boolean"
          },
          "boxed_warning": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "has_boxed_warning"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "scripts/dailymed_proxy.py"
}
