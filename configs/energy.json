{
  "domain": "energy.nexvigilant.com",
  "private": false,
  "copyright": "© 2026 NexVigilant, LLC.",
  "title": "Energy — Metabolism and Charge Metrics",
  "description": "Compute energy charge, metabolic regimes, and temporal transformation waste.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "compute-energy-charge",
      "description": "Calculate Adenylate Energy Charge (EC) = ([ATP] + 0.5[ADP]) / ([ATP] + [ADP] + [AMP]).",
      "parameters": [
        { "name": "atp", "type": "number", "description": "ATP concentration" },
        { "name": "adp", "type": "number", "description": "ADP concentration" },
        { "name": "amp", "type": "number", "description": "AMP concentration" }
      ],
      "outputSchema": {
        "type": "object",
        "properties": { "status": { "type": "string" }, "energy_charge": { "type": "number" }, "interpretation": { "type": "string" } },
        "required": ["status"]
      },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "classify-regime",
      "description": "Determine metabolic regime (Growth, Survival, Dormancy) based on energy charge and flux.",
      "parameters": [
        { "name": "energy_charge", "type": "number", "description": "Calculated energy charge (0.0 - 1.0)" },
        { "name": "flux", "type": "number", "description": "Metabolic flux rate" }
      ],
      "outputSchema": {
        "type": "object",
        "properties": { "status": { "type": "string" }, "regime": { "type": "string" }, "strategy": { "type": "string" } },
        "required": ["status"]
      },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "recommend-strategy",
      "description": "Recommend metabolic strategies for resource allocation.",
      "parameters": [
        { "name": "regime", "type": "string", "description": "Current metabolic regime" },
        { "name": "reserve_ratio", "type": "number", "description": "Ratio of reserves to total capacity" }
      ],
      "outputSchema": {
        "type": "object",
        "properties": { "status": { "type": "string" }, "recommendations": { "type": "array", "items": { "type": "string" } } },
        "required": ["status"]
      },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "analyze-waste",
      "description": "Analyze temporal transformation waste (entropy) in metabolic processes.",
      "parameters": [
        { "name": "efficiency", "type": "number", "description": "Process efficiency (0.0 - 1.0)" },
        { "name": "throughput", "type": "number", "description": "Total throughput" }
      ],
      "outputSchema": {
        "type": "object",
        "properties": { "status": { "type": "string" }, "waste_index": { "type": "number" }, "entropy_delta": { "type": "number" } },
        "required": ["status"]
      },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "temporal-metrics",
      "description": "Calculate temporal metrics for metabolic state transitions.",
      "parameters": [
        { "name": "duration", "type": "number", "description": "Duration of state" },
        { "name": "intensity", "type": "number", "description": "Intensity of metabolic activity" }
      ],
      "outputSchema": {
        "type": "object",
        "properties": { "status": { "type": "string" }, "time_integral": { "type": "number" }, "decay_rate": { "type": "number" } },
        "required": ["status"]
      },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    },
    {
      "name": "classify-waste",
      "description": "Classify waste types in metabolic pathways.",
      "parameters": [
        { "name": "waste_index", "type": "number", "description": "Calculated waste index" }
      ],
      "outputSchema": {
        "type": "object",
        "properties": { "status": { "type": "string" }, "waste_class": { "type": "string" }, "mitigation_priority": { "type": "string" } },
        "required": ["status"]
      },
      "annotations": { "readOnlyHint": true, "destructiveHint": false }
    }
  ]
}
