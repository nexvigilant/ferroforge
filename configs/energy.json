{
  "domain": "energy.nexvigilant.com",
  "private": false,
  "copyright": "\u00a9 2026 NexVigilant, LLC.",
  "title": "Energy \u2014 Metabolism and Charge Metrics",
  "description": "Compute energy charge, metabolic regimes, and temporal transformation waste.",
  "proxy": "rust-native",
  "tools": [
    {
      "name": "compute-energy-charge",
      "description": "Calculate Adenylate Energy Charge (EC) = ([ATP] + 0.5[ADP]) / ([ATP] + [ADP] + [AMP]).",
      "parameters": [
        {
          "name": "atp",
          "type": "number",
          "description": "ATP concentration",
          "required": true
        },
        {
          "name": "adp",
          "type": "number",
          "description": "ADP concentration",
          "required": true
        },
        {
          "name": "amp",
          "type": "number",
          "description": "AMP concentration",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "energy_charge": {
            "type": "number"
          },
          "interpretation": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "classify-regime",
      "description": "Determine metabolic regime (Growth, Survival, Dormancy) based on energy charge and flux.",
      "parameters": [
        {
          "name": "energy_charge",
          "type": "number",
          "description": "Calculated energy charge (0.0 - 1.0)",
          "required": true
        },
        {
          "name": "flux",
          "type": "number",
          "description": "Metabolic flux rate",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "regime": {
            "type": "string"
          },
          "strategy": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "recommend-strategy",
      "description": "Recommend metabolic strategies for resource allocation.",
      "parameters": [
        {
          "name": "regime",
          "type": "string",
          "description": "Current metabolic regime",
          "required": true
        },
        {
          "name": "reserve_ratio",
          "type": "number",
          "description": "Ratio of reserves to total capacity",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "recommendations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "analyze-waste",
      "description": "Analyze temporal transformation waste (entropy) in metabolic processes.",
      "parameters": [
        {
          "name": "efficiency",
          "type": "number",
          "description": "Process efficiency (0.0 - 1.0)",
          "required": true
        },
        {
          "name": "throughput",
          "type": "number",
          "description": "Total throughput",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "waste_index": {
            "type": "number"
          },
          "entropy_delta": {
            "type": "number"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "temporal-metrics",
      "description": "Calculate temporal metrics for metabolic state transitions.",
      "parameters": [
        {
          "name": "duration",
          "type": "number",
          "description": "Duration of state",
          "required": true
        },
        {
          "name": "intensity",
          "type": "number",
          "description": "Intensity of metabolic activity",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "time_integral": {
            "type": "number"
          },
          "decay_rate": {
            "type": "number"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "classify-waste",
      "description": "Classify waste types in metabolic pathways.",
      "parameters": [
        {
          "name": "waste_index",
          "type": "number",
          "description": "Calculated waste index",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "waste_class": {
            "type": "string"
          },
          "mitigation_priority": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "url_pattern": "/*"
}
