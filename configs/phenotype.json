{
  "domain": "phenotype.nexvigilant.com",
  "url_pattern": "/*",
  "title": "Phenotype Analysis",
  "description": "Phenotype classification, molecular characterization, and genotype-phenotype correlation",
  "tools": [
    {
      "name": "phenotype-mutate",
      "description": "Generate mutations of a JSON input for adversarial testing.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "phenotype-verify",
      "description": "Verify schema compatibility between original and mutated JSON.",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "rust-native"
}
