{
  "domain": "www.linkedin.com",
  "url_pattern": "/*",
  "title": "LinkedIn Professional Network",
  "private": true,
  "description": "LinkedIn professional network \u2014 publish posts, track analytics, and search content for PV knowledge sharing",
  "tools": [
    {
      "name": "get-profile",
      "description": "Get your LinkedIn profile information (name, headline, email, picture)",
      "parameters": [],
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "name": {
            "type": "string"
          },
          "given_name": {
            "type": "string"
          },
          "family_name": {
            "type": "string"
          },
          "headline": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "picture": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "profile_url": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-my-posts",
      "description": "List your recent LinkedIn posts with text preview and engagement counts (requires Community Management API)",
      "parameters": [
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum posts to return (default 10, max 50)",
          "required": false
        }
      ],
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | pending_approval"
          },
          "count": {
            "type": "integer"
          },
          "posts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "post_urn": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "created_at": {
                  "type": "string"
                },
                "visibility": {
                  "type": "string"
                }
              }
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-post",
      "description": "Get full text and metadata of a specific LinkedIn post by URN or URL (requires Community Management API)",
      "parameters": [
        {
          "name": "post_id",
          "type": "string",
          "description": "Post URN (urn:li:share:..., urn:li:activity:...) or LinkedIn post URL",
          "required": true
        }
      ],
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "post_urn": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "visibility": {
            "type": "string"
          },
          "media": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-post-analytics",
      "description": "Get engagement metrics (likes, comments, shares) for a post (impressions require Marketing API)",
      "parameters": [
        {
          "name": "post_id",
          "type": "string",
          "description": "Post URN or LinkedIn post URL",
          "required": true
        }
      ],
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "post_urn": {
            "type": "string"
          },
          "impressions": {
            "type": "integer"
          },
          "likes": {
            "type": "integer"
          },
          "comments": {
            "type": "integer"
          },
          "shares": {
            "type": "integer"
          },
          "clicks": {
            "type": "integer"
          },
          "engagement_rate": {
            "type": "number",
            "description": "Engagement % (interactions / impressions * 100)"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "get-comments",
      "description": "Get comments on a specific LinkedIn post (requires Community Management API)",
      "parameters": [
        {
          "name": "post_id",
          "type": "string",
          "description": "Post URN or LinkedIn post URL",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum comments to return (default 20, max 100)",
          "required": false
        }
      ],
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "post_urn": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "comments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "comment_urn": {
                  "type": "string"
                },
                "author_name": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "created_at": {
                  "type": "string"
                },
                "likes": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "search-posts",
      "description": "Search LinkedIn posts by keyword (stub \u2014 requires Content Search API or browser fallback)",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search keywords",
          "required": true
        },
        {
          "name": "limit",
          "type": "integer",
          "description": "Maximum results (default 10, max 25)",
          "required": false
        }
      ],
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | stub | error"
          },
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "message": {
            "type": "string",
            "description": "Status message or stub notice"
          },
          "workaround": {
            "type": "string",
            "description": "Alternative approach"
          }
        },
        "required": [
          "status"
        ]
      }
    }
    ,
    {
      "name": "create-post",
      "description": "Publish a text post to your LinkedIn feed. Use for PV insights, signal findings, and NexVigilant updates.",
      "parameters": [
        {
          "name": "text",
          "type": "string",
          "description": "Post text content (supports Unicode, emoji, hashtags). Max ~3000 chars.",
          "required": true
        },
        {
          "name": "visibility",
          "type": "string",
          "description": "PUBLIC (anyone) or CONNECTIONS (1st degree only). Default: PUBLIC",
          "required": false
        }
      ],
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "post_urn": {
            "type": "string"
          },
          "post_url": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      }
    },
    {
      "name": "reply-to-comment",
      "description": "Reply to a comment on a LinkedIn post.",
      "parameters": [
        {
          "name": "post_id",
          "type": "string",
          "description": "Post URN (urn:li:share:...)",
          "required": true
        },
        {
          "name": "comment_urn",
          "type": "string",
          "description": "Comment URN to reply to (urn:li:comment:...)",
          "required": true
        },
        {
          "name": "text",
          "type": "string",
          "description": "Reply text",
          "required": true
        }
      ],
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "comment_urn": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      }
    }
  ],
  "proxy": "scripts/linkedin_proxy.py"
}
