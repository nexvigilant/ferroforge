{
  "domain": "www.tga.gov.au",
  "url_pattern": "/*",
  "title": "TGA Australia Drug Safety",
  "description": "Australian Therapeutic Goods Administration \u2014 adverse event notifications (DAEN), safety alerts, and product information",
  "tools": [
    {
      "name": "search-daen-reports",
      "description": "Search Database of Adverse Event Notifications (DAEN)",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        },
        {
          "name": "reaction",
          "type": "str",
          "description": "Adverse reaction (MedDRA preferred term)",
          "required": false
        },
        {
          "name": "limit",
          "type": "int",
          "description": "Maximum results to return",
          "required": false,
          "default": "25"
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-safety-alerts",
      "description": "Get TGA safety advisory and alert communications",
      "parameters": [
        {
          "name": "drug_name",
          "type": "string",
          "description": "Drug name (brand or generic)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
