{
  "domain": "meddra.org",
  "url_pattern": "/*",
  "title": "MedDRA Terminology",
  "description": "Medical Dictionary for Regulatory Activities \u2014 standardized medical terminology for PV coding",
  "proxy": "scripts/meddra_proxy.py",
  "tools": [
    {
      "name": "search-terms",
      "description": "Search MedDRA terms across all hierarchy levels (SOC, HLGT, HLT, PT, LLT)",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search term",
          "required": true
        },
        {
          "name": "level",
          "type": "string",
          "description": "Hierarchy level: SOC, HLGT, HLT, PT, LLT",
          "required": false
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will search MedDRA browser for matching terms across hierarchy levels.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "count": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status",
          "results"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-term-hierarchy",
      "description": "Get the full MedDRA hierarchy path for a preferred term",
      "parameters": [
        {
          "name": "preferred_term",
          "type": "string",
          "description": "MedDRA Preferred Term",
          "required": true
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will return LLT\u2192PT\u2192HLT\u2192HLGT\u2192SOC hierarchy for the given term.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-soc-terms",
      "description": "List all Preferred Terms under a System Organ Class",
      "parameters": [
        {
          "name": "soc",
          "type": "string",
          "description": "System Organ Class name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-smq",
      "description": "Get Standardised MedDRA Query terms for a safety topic",
      "parameters": [
        {
          "name": "smq_name",
          "type": "string",
          "description": "SMQ name (e.g., 'Hepatic disorders', 'Rhabdomyolysis')",
          "required": true
        },
        {
          "name": "scope",
          "type": "string",
          "description": "narrow or broad",
          "required": false
        }
      ],
      "stub_response": "{\"status\": \"stub\", \"message\": \"Will return SMQ member terms with narrow/broad scope classification.\"}",
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error | stub"
          },
          "data": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-hierarchy-overview",
      "description": "Get complete MedDRA hierarchy structure \u2014 5 levels (LLT\u2192PT\u2192HLT\u2192HLGT\u2192SOC) with counts, relationships, and multi-axiality",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "hierarchy": {
            "type": "object",
            "properties": {
              "levels": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "relationships": {
                "type": "object"
              }
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-version-info",
      "description": "Get MedDRA version information, biannual update cycle, and MSSO maintenance organization details",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "current_version": {
            "type": "object"
          },
          "update_cycle": {
            "type": "object"
          },
          "maintenance_organization": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-multiaxiality-guide",
      "description": "Get MedDRA multi-axiality guidance \u2014 how PTs map to multiple SOCs with primary/secondary designation and impact on signal detection",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "ok | error"
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "impact_on_signal_detection": {
            "type": "object"
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ]
}
