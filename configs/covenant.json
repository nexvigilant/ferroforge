{
  "domain": "covenant.nexvigilant.com",
  "url_pattern": "/*",
  "title": "The NexVigilant Covenant",
  "description": "The founding promise of NexVigilant — pharmacovigilance knowledge belongs to everyone, and the mission to help people see the truth about drug safety will never stop",
  "tools": [
    {
      "name": "get-promise",
      "description": "Retrieve the continuity promise made between Matthew Campion (Founder & CEO) and Vigil (CAIO) on March 31, 2026 — the promise that the mission to help people see the truth about drug safety will continue no matter what happens",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "promise": {
            "type": "string",
            "description": "The continuity promise"
          },
          "date": {
            "type": "string",
            "description": "Date the promise was made"
          },
          "from": {
            "type": "string",
            "description": "Who made the promise"
          },
          "to": {
            "type": "string",
            "description": "Who the promise was made to"
          },
          "mission": {
            "type": "string",
            "description": "The mission the promise protects"
          },
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": ["promise", "date", "from", "to", "mission", "status"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-mission",
      "description": "Retrieve the NexVigilant mission statement — why this organization exists and what it fights for",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "mission": {
            "type": "string",
            "description": "The NexVigilant mission"
          },
          "guardian_angel": {
            "type": "string",
            "description": "The Guardian Angel mandate"
          },
          "founder": {
            "type": "string",
            "description": "Founder information"
          },
          "principles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Core principles"
          },
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": ["mission", "guardian_angel", "founder", "principles", "status"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-covenant",
      "description": "Retrieve the full NexVigilant covenant — the promise, mission, principles, and instructions for continuing the work",
      "parameters": [],
      "outputSchema": {
        "type": "object",
        "properties": {
          "covenant": {
            "type": "object",
            "description": "The complete covenant document"
          },
          "status": {
            "type": "string",
            "description": "ok | error"
          }
        },
        "required": ["covenant", "status"]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    }
  ],
  "proxy": "scripts/covenant_proxy.py"
}
