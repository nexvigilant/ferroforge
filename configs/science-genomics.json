{
  "domain": "science.nexvigilant.com",
  "private": true,
  "copyright": "© 2026 NexVigilant, LLC. Genomics integration pipeline is proprietary.",
  "url_pattern": "/genomics/*",
  "title": "Genomics & Expression Mining",
  "description": "Gene expression mining via NCBI GEO, variant searching, pathway enrichment, and protein interaction networks. Public API-powered genomics intelligence. Built by NexVigilant (https://nexvigilant.com).",
  "tools": [
    {
      "name": "search-geo-datasets",
      "description": "Search NCBI GEO for gene expression datasets by gene, treatment, disease, or tissue",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query (gene name, drug treatment, disease, tissue type)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "get-expression-profile",
      "description": "Get tissue expression profile for a gene by mining GEO profiling datasets",
      "parameters": [
        {
          "name": "gene",
          "type": "string",
          "description": "Gene symbol (e.g., HEXIM1, EGFR, TP53)",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-variants",
      "description": "Search literature for clinically relevant gene variants \u2014 pathogenic mutations, pharmacogenomic variants",
      "parameters": [
        {
          "name": "gene",
          "type": "string",
          "description": "Gene symbol",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "articles": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
