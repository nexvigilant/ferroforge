      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "articles": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "status"
        ]
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false
      }
    },
    {
      "name": "search-protein-interactions",
      "description": "Find protein-protein interaction partners from STRING/BioGRID literature",
      "parameters": [
        {
          "name": "gene",
          "type": "string",
          "description": "Gene/protein name",
          "required": true
        }
      ],
      "outputSchema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
